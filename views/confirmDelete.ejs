<%- include('cabecalho', { titulo: 'Confirmar Exclusão' }) %>

<main id="conteudo-principal-form" class="container my-5">
  <div class="row">
    <div class="col-md-6 offset-md-3">
      <div class="card shadow">
        <div class="card-header bg-danger text-white">
          <h4 class="mb-0 fs-5 fw-bold">Confirmar Exclusão</h4>
        </div>
        <div class="card-body p-4">
          <p class="mb-1">Tem certeza que deseja excluir este registro?</p>
          <p class="text-muted" style="font-size:0.813rem">Esta ação não pode ser desfeita.</p>

          <div class="d-flex gap-2 mt-4">
            <form method="POST" action="delete" class="d-inline">
              <button type="submit" class="btn btn-danger">
                <i class="bi bi-trash"></i> Confirmar Exclusão
              </button>
            </form>
            <a href="javascript:history.back()" class="btn btn-secondary">
              <i class="bi bi-arrow-left"></i> Cancelar
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('rodape') %>
