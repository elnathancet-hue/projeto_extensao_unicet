<%- include('cabecalho', { titulo: 'Dashboard' }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-1">Bem-vindo, <%= sessionUsuario %>!</h1>
    <p class="text-muted mb-0" style="font-size:0.875rem">Gerenciador de Projetos de Extensão</p>
  </div>
  <span class="badge bg-info">
    <i class="bi bi-calendar3"></i> <%= new Date().toLocaleDateString('pt-BR') %>
  </span>
</div>

<!-- Acesso Rápido -->
<h3 class="mb-3">Acesso Rápido</h3>
<div class="row mb-4">
  <div class="col-md-3 mb-3">
    <div class="card module-card" style="border-left: 4px solid var(--bs-success);">
      <div class="card-body text-center">
        <div class="card-icon" style="color: var(--bs-success);"><i class="bi bi-briefcase-fill"></i></div>
        <h5 class="card-title">Projetos</h5>
        <p class="card-text text-muted">Projetos de Extensão</p>
        <a href="/projeto_extensao" class="btn btn-primary btn-sm">Acessar</a>
      </div>
    </div>
  </div>
  <div class="col-md-3 mb-3">
    <div class="card module-card" style="border-left: 4px solid var(--brand);">
      <div class="card-body text-center">
        <div class="card-icon" style="color: var(--brand);"><i class="bi bi-people-fill"></i></div>
        <h5 class="card-title">Pessoas</h5>
        <p class="card-text text-muted">Cadastro de pessoas</p>
        <a href="/pessoa" class="btn btn-primary btn-sm">Acessar</a>
      </div>
    </div>
  </div>
  <div class="col-md-3 mb-3">
    <div class="card module-card" style="border-left: 4px solid #0d6efd;">
      <div class="card-body text-center">
        <div class="card-icon" style="color: #0d6efd;"><i class="bi bi-cash-stack"></i></div>
        <h5 class="card-title">Custos</h5>
        <p class="card-text text-muted">Custos dos projetos</p>
        <a href="/projeto_custo" class="btn btn-primary btn-sm">Acessar</a>
      </div>
    </div>
  </div>
  <div class="col-md-3 mb-3">
    <div class="card module-card" style="border-left: 4px solid var(--bs-warning);">
      <div class="card-body text-center">
        <div class="card-icon" style="color: var(--bs-warning);"><i class="bi bi-star-fill"></i></div>
        <h5 class="card-title">Avaliações</h5>
        <p class="card-text text-muted">Avaliações institucionais</p>
        <a href="/avaliacao_institucional" class="btn btn-primary btn-sm">Acessar</a>
      </div>
    </div>
  </div>
</div>

<!-- Gerenciamento -->
<div class="row mb-4">
  <div class="col-md-3 mb-3">
    <div class="card module-card">
      <div class="card-body text-center">
        <div class="card-icon" style="color: var(--brand);"><i class="bi bi-gear"></i></div>
        <h5 class="card-title">Configurações</h5>
        <a href="/configuracoes" class="btn btn-outline-primary btn-sm">Gerenciar</a>
      </div>
    </div>
  </div>
</div>

<!-- Footer -->
<div class="mt-4 pt-3 border-top text-muted text-center">
  <p class="mb-0"><small>Sistema de Projetos de Extensão - UNI-CET 2025</small></p>
</div>

<%- include('rodape') %>
