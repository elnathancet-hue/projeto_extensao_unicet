<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof titulo !== 'undefined' ? titulo : 'Extensão Acadêmica - UNI-CET' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <div class="layout-wrapper">

    <!-- Sidebar -->
    <nav class="sidebar" id="sidebarNav">
      <div class="logo-section">
        <h5><i class="bi bi-mortarboard"></i> Extensão</h5>
        <small>UNI-CET</small>
      </div>

      <% if (sessionUsuario) { %>
        <div class="user-info">
          <strong><i class="bi bi-person-circle"></i> <%= sessionUsuario %></strong>
          <br>
          <small><%= sessionTipo || '' %></small>
        </div>
      <% } %>

      <a href="/logo" class="<%= currentPath === '/logo' ? 'active' : '' %>">
        <i class="bi bi-house"></i> Home
      </a>

      <!-- Projetos -->
      <div class="sidebar-group">
        <a href="#menuProjetos" class="sidebar-toggle" data-bs-toggle="collapse"
           aria-expanded="<%= ['/projeto_extensao','/projeto_custo','/avaliacao_institucional','/cronograma','/questionario'].some(p => currentPath.startsWith(p)) ? 'true' : 'false' %>">
          <i class="bi bi-briefcase"></i> Projetos
          <i class="bi bi-chevron-down sidebar-chevron ms-auto"></i>
        </a>
        <div class="collapse <%= ['/projeto_extensao','/projeto_custo','/avaliacao_institucional','/cronograma','/questionario'].some(p => currentPath.startsWith(p)) ? 'show' : '' %>" id="menuProjetos">
          <a href="/projeto_extensao" class="sidebar-sub <%= currentPath.startsWith('/projeto_extensao') ? 'active' : '' %>"><i class="bi bi-briefcase"></i> Projetos de Extensão</a>
          <a href="/projeto_custo" class="sidebar-sub <%= currentPath.startsWith('/projeto_custo') ? 'active' : '' %>"><i class="bi bi-currency-dollar"></i> Custo Projetos</a>
          <a href="/avaliacao_institucional" class="sidebar-sub <%= currentPath.startsWith('/avaliacao_institucional') ? 'active' : '' %>"><i class="bi bi-star"></i> Avaliações</a>
          <a href="/cronograma" class="sidebar-sub <%= currentPath.startsWith('/cronograma') ? 'active' : '' %>"><i class="bi bi-clock"></i> Cronograma</a>
          <a href="/questionario" class="sidebar-sub <%= currentPath.startsWith('/questionario') ? 'active' : '' %>"><i class="bi bi-clipboard-check"></i> Questionário</a>
        </div>
      </div>

      <!-- Configuração -->
      <div class="sidebar-group">
        <a href="#menuConfig" class="sidebar-toggle" data-bs-toggle="collapse"
           aria-expanded="<%= currentPath.startsWith('/configuracoes') || ['/tipo_pessoa','/tipo_plano','/tipo_instituicao','/tipo_acao','/publico_alvo','/papel_projeto','/faixa_etaria','/escolaridade','/linha_programatica','/pessoa','/curso','/instituicao','/local_execucao'].some(p => currentPath.startsWith(p)) ? 'true' : 'false' %>">
          <i class="bi bi-gear"></i> Configuração
          <i class="bi bi-chevron-down sidebar-chevron ms-auto"></i>
        </a>
        <div class="collapse <%= currentPath.startsWith('/configuracoes') || ['/tipo_pessoa','/tipo_plano','/tipo_instituicao','/tipo_acao','/publico_alvo','/papel_projeto','/faixa_etaria','/escolaridade','/linha_programatica','/pessoa','/curso','/instituicao','/local_execucao'].some(p => currentPath.startsWith(p)) ? 'show' : '' %>" id="menuConfig">
          <a href="/configuracoes" id="sidebar-link-formulario" class="sidebar-sub <%= (currentPath.startsWith('/configuracoes') || ['/tipo_pessoa','/tipo_plano','/tipo_instituicao','/tipo_acao','/publico_alvo','/papel_projeto','/faixa_etaria','/escolaridade','/linha_programatica'].some(p => currentPath.startsWith(p))) && !['/pessoa','/curso','/instituicao','/local_execucao'].some(p => currentPath.startsWith(p)) ? 'active' : '' %>"><i class="bi bi-sliders"></i> Formulário</a>
          <a href="/configuracoes#secao-cadastro" id="sidebar-link-cadastro" class="sidebar-sub <%= ['/pessoa','/curso','/instituicao','/local_execucao'].some(p => currentPath.startsWith(p)) ? 'active' : '' %>"><i class="bi bi-database"></i> Cadastro</a>
        </div>
      </div>

      <div class="sidebar-bottom">
        <a href="/logout"><i class="bi bi-box-arrow-right"></i> Sair</a>
      </div>
    </nav>

    <!-- Botão hamburger mobile -->
    <button class="sidebar-toggle-mobile d-md-none" id="sidebarToggle" type="button">
      <i class="bi bi-list"></i>
    </button>

    <!-- Conteúdo principal (aberto aqui, fechado no rodape.ejs) -->
    <div class="layout-content">
