<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof titulo !== 'undefined' ? titulo : 'Extensão Acadêmica - UNI-CET' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <div class="layout-wrapper">

    <!-- Sidebar -->
    <nav class="sidebar" id="sidebarNav">
      <div class="logo-section">
        <h5><i class="bi bi-mortarboard"></i> Extensão</h5>
        <small>UNI-CET</small>
      </div>

      <div class="sidebar-menu">
        <a href="/logo" class="<%= currentPath === '/logo' ? 'active' : '' %>">
          <i class="bi bi-house"></i> Home
        </a>

        <!-- Projetos de Extensão (link direto) -->
        <a href="/projeto_extensao" class="<%= currentPath.startsWith('/projeto_extensao') || currentPath.startsWith('/projeto_custo') || currentPath.startsWith('/avaliacao_institucional') || currentPath.startsWith('/cronograma') || currentPath.startsWith('/questionario') ? 'active' : '' %>">
          <i class="bi bi-briefcase"></i> Projetos de Extensão
        </a>

        <!-- Configuração -->
        <div class="sidebar-group">
          <a href="#menuConfig" class="sidebar-toggle" data-bs-toggle="collapse"
             aria-expanded="<%= currentPath.startsWith('/configuracoes') || ['/tipo_pessoa','/tipo_plano','/tipo_instituicao','/tipo_acao','/publico_alvo','/papel_projeto','/faixa_etaria','/escolaridade','/linha_programatica','/pessoa','/curso','/instituicao','/local_execucao'].some(p => currentPath.startsWith(p)) ? 'true' : 'false' %>">
            <i class="bi bi-gear"></i> Configuração
            <i class="bi bi-chevron-down sidebar-chevron ms-auto"></i>
          </a>
          <div class="collapse <%= currentPath.startsWith('/configuracoes') || ['/tipo_pessoa','/tipo_plano','/tipo_instituicao','/tipo_acao','/publico_alvo','/papel_projeto','/faixa_etaria','/escolaridade','/linha_programatica','/pessoa','/curso','/instituicao','/local_execucao'].some(p => currentPath.startsWith(p)) ? 'show' : '' %>" id="menuConfig">
            <a href="/configuracoes" id="sidebar-link-formulario" class="sidebar-sub <%= (currentPath.startsWith('/configuracoes') || ['/tipo_pessoa','/tipo_plano','/tipo_instituicao','/tipo_acao','/publico_alvo','/papel_projeto','/faixa_etaria','/escolaridade','/linha_programatica'].some(p => currentPath.startsWith(p))) && !['/pessoa','/curso','/instituicao','/local_execucao'].some(p => currentPath.startsWith(p)) ? 'active' : '' %>"><i class="bi bi-sliders"></i> Formulário</a>
            <a href="/configuracoes#secao-cadastro" id="sidebar-link-cadastro" class="sidebar-sub <%= ['/pessoa','/curso','/instituicao','/local_execucao'].some(p => currentPath.startsWith(p)) ? 'active' : '' %>"><i class="bi bi-database"></i> Cadastro</a>
          </div>
        </div>
      </div>

      <div class="sidebar-bottom">
        <div class="sidebar-user-mini">
          <div class="sidebar-avatar"><%= sessionUsuario ? sessionUsuario.charAt(0).toUpperCase() : 'U' %></div>
          <div class="sidebar-user-detail">
            <span class="sidebar-user-name"><%= sessionUsuario || 'Usuário' %></span>
            <span class="sidebar-user-role"><%= sessionTipo || '' %></span>
          </div>
        </div>
        <a href="/logout" class="sidebar-logout"><i class="bi bi-box-arrow-right"></i> Sair</a>
      </div>
    </nav>

    <!-- Botão hamburger mobile -->
    <button class="sidebar-toggle-mobile d-md-none" id="sidebarToggle" type="button">
      <i class="bi bi-list"></i>
    </button>

    <!-- Conteúdo principal -->
    <div class="layout-content">

      <!-- Top bar -->
      <div class="topbar">
        <div class="topbar-left">
          <nav class="topbar-breadcrumb">
            <a href="/logo">Home</a>
            <% if (currentPath !== '/logo') { %>
              <span class="topbar-sep">/</span>
              <span><%= typeof titulo !== 'undefined' ? titulo : '' %></span>
            <% } %>
          </nav>
        </div>
        <div class="topbar-right">
          <button class="topbar-icon-btn" title="Notificações">
            <i class="bi bi-bell"></i>
            <span class="topbar-badge">0</span>
          </button>
          <div class="topbar-divider"></div>
          <div class="topbar-user">
            <div class="topbar-avatar"><%= sessionUsuario ? sessionUsuario.charAt(0).toUpperCase() : 'U' %></div>
            <div class="topbar-user-info d-none d-md-block">
              <span class="topbar-user-name"><%= sessionUsuario || 'Usuário' %></span>
              <span class="topbar-user-role"><%= sessionTipo || '' %></span>
            </div>
          </div>
        </div>
      </div>
