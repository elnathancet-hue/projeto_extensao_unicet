<%- include('../cabecalho', { titulo: isEdit ? 'Editar Cronograma' : 'Cadastrar Cronograma' }) %>

<% const registro = typeof cronograma !== 'undefined' ? cronograma : null; %>
<% const registroId = registro && registro['id']; %>

<div class="container my-5">
  <div class="d-flex justify-content-center">
    <div class="w-100" style="max-width: 600px;">

      <div class="mb-4">
        <h1 class="fs-4 fw-bold mb-0 border-bottom pb-2 text-center">
          <i class="bi bi-calendar-event"></i>
          <%= isEdit ? 'Editar Atividade' : 'Cadastrar Nova Atividade' %>
        </h1>
      </div>

      <form method="POST" action="<%= isEdit ? '/cronograma/' + registroId + '/edit' : '/cronograma/cadastrar' %>">

        <div class="mb-3">
          <label for="campo-numero" class="form-label">
            <i class="bi bi-list-ol"></i> Nº da Etapa
          </label>
          <input
            id="campo-numero"
            name="numero"
            type="number"
            class="form-control"
            value="<%= registro && registro['numero'] != null ? registro['numero'] : '' %>"
            placeholder="Ex: 1"
            required
          >
        </div>

        <div class="mb-3">
          <label for="campo-etapa" class="form-label">
            <i class="bi bi-card-text"></i> Etapa
          </label>
          <input
            id="campo-etapa"
            name="etapa"
            type="text"
            class="form-control"
            value="<%= registro && registro['etapa'] != null ? registro['etapa'] : '' %>"
            placeholder="Descrição da atividade"
            required
          >
        </div>

        <div class="row">
          <div class="col-md-6 mb-3">
            <label for="campo-data" class="form-label">
              <i class="bi bi-calendar"></i> Data
            </label>
            <input
              id="campo-data"
              name="data"
              type="date"
              class="form-control"
              value="<%= registro && registro['data'] ? new Date(registro['data']).toISOString().split('T')[0] : '' %>"
            >
          </div>

          <div class="col-md-6 mb-3">
            <label for="campo-hora" class="form-label">
              <i class="bi bi-clock"></i> Hora
            </label>
            <input
              id="campo-hora"
              name="hora"
              type="time"
              class="form-control"
              value="<%= registro && registro['hora'] ? registro['hora'].toString().slice(0,5) : '' %>"
            >
          </div>
        </div>

        <div class="mb-3">
          <label for="campo-local" class="form-label">
            <i class="bi bi-geo-alt"></i> Local
          </label>
          <input
            id="campo-local"
            name="local"
            type="text"
            class="form-control"
            value="<%= registro && registro['local'] != null ? registro['local'] : '' %>"
            placeholder="Ex: Sala 101, Online, Auditório..."
          >
        </div>

        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4 pt-3 border-top">
          <a href="/cronograma" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Voltar
          </a>
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg"></i>
            <%= isEdit ? 'Salvar Alterações' : 'Cadastrar' %>
          </button>
        </div>

      </form>
    </div>
  </div>
</div>

<%- include('../rodape') %>