<%- include('../cabecalho', { titulo: isEdit ? 'Editar Avaliacao Institucional' : 'Cadastrar Avaliacao Institucional' }) %>

<% const registro = typeof avaliacao_institucional !== 'undefined' ? avaliacao_institucional : null; %>
<% const registroId = registro && registro['id_avaliacao']; %>
<main id="conteudo-principal-form" class="container my-5">
  <section class="card shadow p-4 p-md-5">
    <h1 class="fs-4 fw-bold mb-4 border-bottom pb-3">
      <%= isEdit ? 'Editar avaliacao institucional' : 'Cadastrar avaliacao institucional' %>
    </h1>

    <% if (projetos && projetos.length === 0) { %>
      <div class="alert alert-warning" role="alert">
        <i class="bi bi-exclamation-triangle-fill flex-shrink-0 me-2"></i>
        É necessário primeiro cadastrar um <strong>projeto de extensão</strong> antes de registrar uma nova avaliação institucional.
      </div>
      <div class="mt-3">
        <a href="/projeto_extensao/forms/projeto_extensao" class="btn btn-primary">Cadastrar Projeto</a>
        <a href="/avaliacao_institucional/consultas/avaliacao_institucional" class="btn btn-secondary">Voltar</a>
      </div>
    <% } else { %>
    <form method="POST" action="<%= isEdit ? '/avaliacao_institucional/' + registroId + '/edit' : '/avaliacao_institucional/cadastrar' %>">

      <!-- id_avaliacao passa a ser invisivel durante a criacao e auto incrementavel no bd -->
      <% if (isEdit) { %>
        <div class="mb-3">
          <label for="campo-id_avaliacao" class="form-label">Id Avaliação</label>
          <input
            id="campo-id_avaliacao"
            name="id_avaliacao"
            class="form-control bg-light"
            value="<%= registro && registro['id_avaliacao'] != null ? registro['id_avaliacao'] : '' %>"
            readonly
          >
        </div>
      <% } else { %>
        <input type="hidden" name="id_avaliacao" value="">
      <% } %>

      <!-- id_projeto vira select -->
      <div class="mb-3">
        <label for="campo-id_projeto" class="form-label">Projeto de Extensão</label>
        <select
          id="campo-id_projeto"
          name="id_projeto"
          class="form-select"
          required
        >
          <option value="">Selecione o Projeto</option>
          <% if (typeof projetos !== 'undefined') { %>
            <% projetos.forEach(proj => { %>
              <option value="<%= proj.id_projeto %>" <%= (registro && registro.id_projeto == proj.id_projeto) ? 'selected' : '' %>>
                <%= proj.titulo %> <!-- Ou o campo que represente o titulo no seu bd para projeto -->
              </option>
            <% }) %>
          <% } %>
        </select>
      </div>

      <div class="mb-3">
        <label for="campo-criterios_avaliacao" class="form-label">Critérios de Avaliação</label>
        <input
          id="campo-criterios_avaliacao"
          name="criterios_avaliacao"
          class="form-control"
          value="<%= registro && registro['criterios_avaliacao'] != null ? registro['criterios_avaliacao'] : '' %>"
          placeholder="Ex: Assiduidade, Notas Reunião..."
          required
        >
      </div>

      <div class="mb-3">
        <label for="campo-metodologia_avaliacao" class="form-label">Metodologia de Avaliação</label>
        <input
          id="campo-metodologia_avaliacao"
          name="metodologia_avaliacao"
          class="form-control"
          value="<%= registro && registro['metodologia_avaliacao'] != null ? registro['metodologia_avaliacao'] : '' %>"
          placeholder="Descreva a metodologia"
          required
        >
      </div>

      <div class="mb-3">
        <label for="campo-forma_apresentacao_relatorio" class="form-label">Forma de Apresentação Final (Relatório)</label>
        <input
          id="campo-forma_apresentacao_relatorio"
          name="forma_apresentacao_relatorio"
          class="form-control"
          value="<%= registro && registro['forma_apresentacao_relatorio'] != null ? registro['forma_apresentacao_relatorio'] : '' %>"
          placeholder="Descreva a forma de apresentaçao"
          required
        >
      </div>
      
      <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary">
          <%= isEdit ? 'Salvar alterações' : 'Cadastrar' %>
        </button>
        <a href="/logo" class="btn btn-secondary">Voltar ao Inicio</a>
      </div>
    </form>

    <% if (isEdit && registroId) { %>
    <form method="POST" action="/avaliacao_institucional/<%= registroId %>/delete" class="mt-3">
      <button type="submit" class="btn btn-danger">Excluir</button>
    </form>
    <% } %>
    
    <% } /* end if projetos.length === 0 */ %>
  </section>
</main>
<%- include('../rodape') %>