<%- include('../cabecalho', { titulo: 'Relatório de Extensão' }) %>

<%
  const p = projeto || {};
  const formatDate = (d) => {
    if (!d) return '---';
    try { return new Date(d).toLocaleDateString('pt-BR'); } catch(e) { return '---'; }
  };
%>

<main class="container my-5">
  <section class="card shadow p-4 p-md-5">

    <h1 class="fs-4 fw-bold mb-4 border-bottom pb-3">
      <i class="bi bi-file-earmark-text"></i> Relatório de Extensão - <%= p.titulo || '' %>
    </h1>

    <!-- ===== DADOS DO PROJETO (readonly) ===== -->
    <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-info-circle"></i> Dados do Projeto</h5>

    <div class="row mb-3">
      <div class="col-md-6">
        <label class="form-label fw-semibold">Tipo de Extensão</label>
        <div class="form-control bg-light"><%= p.tipo_plano_nome || '---' %></div>
      </div>
      <div class="col-md-6">
        <label class="form-label fw-semibold">Título</label>
        <div class="form-control bg-light"><%= p.titulo || '---' %></div>
      </div>
    </div>

    <div class="row mb-3">
      <div class="col-md-4">
        <label class="form-label fw-semibold">Período</label>
        <div class="form-control bg-light">
          <%= formatDate(p.periodo_inicio) %> a <%= formatDate(p.periodo_fim) %>
        </div>
      </div>
      <div class="col-md-4">
        <label class="form-label fw-semibold">Tipo de Ação</label>
        <div class="form-control bg-light">
          <%= (p.tiposAcao && p.tiposAcao.length > 0) ? p.tiposAcao.map(t => t.nome).join(', ') : '---' %>
        </div>
      </div>
      <div class="col-md-4">
        <label class="form-label fw-semibold">Área Temática / Linha Programática</label>
        <div class="form-control bg-light">
          <%= (p.linhas && p.linhas.length > 0) ? p.linhas.map(l => l.nome).join(', ') : '---' %>
        </div>
      </div>
    </div>

    <div class="row mb-3">
      <div class="col-md-6">
        <label class="form-label fw-semibold">Carga Horária</label>
        <div class="form-control bg-light"><%= p.carga_horaria_total || '---' %> h</div>
      </div>
    </div>

    <% if (p.locais && p.locais.length > 0) { %>
    <div class="mb-3">
      <label class="form-label fw-semibold">Local de Execução</label>
      <div class="form-control bg-light" style="height:auto; min-height:38px;">
        <% p.locais.forEach((loc, i) => { %>
          <%= loc.endereco %> - <%= loc.bairro %>, <%= loc.cidade %><%= i < p.locais.length - 1 ? '; ' : '' %>
        <% }) %>
      </div>
    </div>
    <% } %>

    <!-- ===== II - EQUIPE EXECUTORA (readonly) ===== -->
    <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-people"></i> II - Equipe Executora</h5>

    <div class="row mb-3">
      <div class="col-md-6">
        <label class="form-label fw-semibold">Coordenador</label>
        <div class="form-control bg-light"><%= p.coordenador_nome || '---' %></div>
      </div>
      <div class="col-md-6">
        <label class="form-label fw-semibold">Cursos</label>
        <div class="form-control bg-light">
          <%= (p.cursos && p.cursos.length > 0) ? p.cursos.map(c => c.nome_curso).join(', ') : '---' %>
        </div>
      </div>
    </div>

    <% if (p.pessoas && p.pessoas.length > 0) { %>
    <div class="mb-3">
      <label class="form-label fw-semibold">Professores / Técnicos</label>
      <div class="form-control bg-light" style="height:auto; min-height:38px;">
        <% p.pessoas.forEach((pe, i) => { %>
          <%= pe.nome %> (<%= pe.papel %>)<%= i < p.pessoas.length - 1 ? ', ' : '' %>
        <% }) %>
      </div>
    </div>
    <% } %>

    <!-- ===== III - PÚBLICO-ALVO E ABRANGÊNCIA (readonly) ===== -->
    <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-person-lines-fill"></i> III - Público-Alvo e Abrangência</h5>
    <div class="mb-3">
      <div class="form-control bg-light"><%= p.publico_alvo_nome || '---' %></div>
    </div>

    <!-- ===== IV - OBJETIVOS DA AÇÃO (readonly) ===== -->
    <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-bullseye"></i> IV - Objetivos da Ação</h5>
    <div class="mb-3">
      <div class="form-control bg-light" style="height:auto; min-height:80px; white-space:pre-wrap;"><%= p.objetivo || '---' %></div>
    </div>

    <!-- ===== VII - ATIVIDADES DESENVOLVIDAS (gerenciavel - FORA do form principal) ===== -->
    <h5 class="fw-bold mt-4 mb-3">
      <i class="bi bi-calendar-range"></i> VII - Atividades Desenvolvidas
      <button type="button" class="btn btn-sm btn-outline-primary float-end" style="font-size:0.688rem" onclick="document.getElementById('form-add-cronograma-rel').style.display = document.getElementById('form-add-cronograma-rel').style.display === 'none' ? 'block' : 'none'"><i class="bi bi-plus"></i> Adicionar Atividade</button>
    </h5>
    <% if (p.cronograma && p.cronograma.length > 0) { %>
    <div class="table-responsive mb-3">
      <table class="table table-bordered table-striped">
        <thead class="table-light">
          <tr>
            <th>Nº</th>
            <th>Etapa</th>
            <th>Data</th>
            <th>Hora</th>
            <th>Local</th>
            <th style="width:60px"></th>
          </tr>
        </thead>
        <tbody>
          <% p.cronograma.forEach(c => { %>
          <tr>
            <td><%= c.numero || '' %></td>
            <td><%= c.etapa || '' %></td>
            <td><%= formatDate(c.data) %></td>
            <td><%= c.hora || '' %></td>
            <td><%= c.local || '' %></td>
            <td>
              <form method="POST" action="/projeto_extensao/<%= p.id_projeto %>/cronograma/<%= c.id %>/delete" onsubmit="return confirm('Excluir esta atividade?')">
                <input type="hidden" name="from" value="relatorio">
                <button type="submit" class="btn btn-sm btn-outline-danger" style="font-size:0.625rem; padding:1px 4px" title="Excluir"><i class="bi bi-trash"></i></button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <p class="text-muted text-center py-3" style="font-size:0.75rem"><i class="bi bi-info-circle"></i> Nenhuma atividade cadastrada. Clique em "Adicionar Atividade" para incluir.</p>
    <% } %>
    <div id="form-add-cronograma-rel" style="display:none; border:1px solid #dee2e6; border-radius:6px; padding:12px; margin-bottom:16px; background:#f9fafb">
      <form method="POST" action="/projeto_extensao/<%= p.id_projeto %>/cronograma" class="row g-2 align-items-end">
        <input type="hidden" name="from" value="relatorio">
        <div class="col-md-1"><label class="form-label" style="font-size:0.688rem">Nº</label><input name="numero" type="number" class="form-control form-control-sm" placeholder="1" required style="font-size:0.75rem"></div>
        <div class="col-md-3"><label class="form-label" style="font-size:0.688rem">Etapa</label><input name="etapa" class="form-control form-control-sm" placeholder="Descrição da atividade" required style="font-size:0.75rem"></div>
        <div class="col-md-2"><label class="form-label" style="font-size:0.688rem">Data</label><input name="data" type="date" class="form-control form-control-sm" style="font-size:0.75rem"></div>
        <div class="col-md-2"><label class="form-label" style="font-size:0.688rem">Hora</label><input name="hora" type="time" class="form-control form-control-sm" style="font-size:0.75rem"></div>
        <div class="col-md-3"><label class="form-label" style="font-size:0.688rem">Local</label><input name="local" class="form-control form-control-sm" placeholder="Sala, Auditório..." style="font-size:0.75rem"></div>
        <div class="col-md-1"><button type="submit" class="btn btn-sm btn-primary" style="font-size:0.688rem"><i class="bi bi-check-lg"></i> Salvar</button></div>
      </form>
    </div>

    <!-- ===== FORM DO RELATÓRIO (campos editáveis) ===== -->
    <form method="POST" action="/projeto_extensao/<%= p.id_projeto %>/relatorio">

      <!-- ===== V - JUSTIFICATIVA (editavel) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-journal-text"></i> V - Justificativa</h5>
      <div class="mb-3">
        <p class="text-muted" style="font-size:0.7rem;margin-bottom:6px">Apresente a motivação da ação: demanda social identificada, problemas enfrentados, importância para a comunidade.</p>
        <textarea name="justificativa" class="form-control" rows="5" placeholder="Descreva a justificativa da ação..."><%= p.justificativa || '' %></textarea>
      </div>

      <!-- ===== VI - METODOLOGIA (readonly) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-diagram-3"></i> VI - Metodologia</h5>
      <div class="mb-3">
        <div class="form-control bg-light" style="height:auto; min-height:80px; white-space:pre-wrap;"><%= p.metodologia || '---' %></div>
      </div>

      <!-- ===== VIII - RESULTADOS ALCANÇADOS (editavel) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-check2-circle"></i> VIII - Resultados Alcançados</h5>
      <div class="mb-3">
        <p class="text-muted" style="font-size:0.7rem;margin-bottom:6px">Inclua resultados qualitativos (mudanças percebidas) e quantitativos (número de beneficiados, atividades executadas).</p>
        <textarea name="resultados_alcancados" class="form-control" rows="5" placeholder="Descreva os resultados alcançados..."><%= p.resultados_alcancados || '' %></textarea>
      </div>

      <!-- ===== IX - AVALIAÇÃO DA AÇÃO (editavel) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-chat-left-text"></i> IX - Avaliação da Ação</h5>

      <div class="mb-3">
        <label class="form-label fw-semibold">Avaliação da Comunidade</label>
        <p class="text-muted" style="font-size:0.7rem;margin-bottom:6px">Como foi coletado o feedback? O que foi positivo? O que pode ser melhorado?</p>
        <textarea name="avaliacao_comunidade" class="form-control" rows="5" placeholder="Descreva a avaliação da comunidade sobre a ação..."><%= p.avaliacao_comunidade || '' %></textarea>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">Avaliação da Equipe</label>
        <p class="text-muted" style="font-size:0.7rem;margin-bottom:6px">O que funcionou bem? Dificuldades enfrentadas? Aprendizagens para ações futuras?</p>
        <textarea name="avaliacao_equipe" class="form-control" rows="5" placeholder="Descreva a avaliação da equipe executora sobre a ação..."><%= p.avaliacao_equipe || '' %></textarea>
      </div>

      <!-- ===== X - PRODUTOS GERADOS (editavel) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-box-seam"></i> X - Produtos Gerados</h5>
      <div class="mb-3">
        <p class="text-muted" style="font-size:0.7rem;margin-bottom:6px">Materiais didáticos, artigos, cartilhas, vídeos, protótipos. Indicar links ou anexos.</p>
        <textarea name="produtos_gerados" class="form-control" rows="5" placeholder="Liste os produtos gerados pela ação..."><%= p.produtos_gerados || '' %></textarea>
      </div>

      <!-- ===== XI - VINCULAÇÃO COM OS ODS (editavel) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-globe2"></i> XI - Vinculação com os ODS</h5>
      <div class="mb-3">
        <p class="text-muted" style="font-size:0.7rem;margin-bottom:6px">Relacione com 1 a 3 ODS da Agenda 2030 da ONU (ex: ODS 4 – Educação de qualidade).</p>
        <textarea name="ods" class="form-control" rows="4" placeholder="Indique os Objetivos de Desenvolvimento Sustentável (ODS) vinculados..."><%= p.ods || '' %></textarea>
      </div>

      <!-- ===== XIII - OBSERVAÇÃO FINAL (editavel) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-pencil-square"></i> XIII - Observação Final</h5>
      <div class="mb-3">
        <textarea name="observacao_final" class="form-control" rows="5" placeholder="Observações finais..."><%= p.observacao_final || 'Este relatório atende às diretrizes da Resolução CNE/CES nº 7/2018 e às orientações da política de extensão da instituição, visando demonstrar o impacto social da ação, sua articulação com o ensino e a formação cidadã dos estudantes.' %></textarea>
      </div>

      <!-- ===== XV - ANEXOS (editavel) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-paperclip"></i> XV - Anexos</h5>
      <div class="mb-3">
        <textarea name="anexos" class="form-control" rows="4" placeholder="Liste os anexos (fotos, listas de presença, materiais, etc.)..."><%= p.anexos || '' %></textarea>
      </div>

      <!-- ===== BOTÕES ===== -->
      <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-sm btn-primary">
          <i class="bi bi-save"></i> Salvar
        </button>
        <a href="/projeto_extensao/<%= p.id_projeto %>/relatorio/pdf" class="btn btn-sm btn-success" target="_blank">
          <i class="bi bi-filetype-pdf"></i> Baixar PDF
        </a>
        <a href="/projeto_extensao" class="btn btn-sm btn-secondary">
          <i class="bi bi-arrow-left"></i> Voltar
        </a>
      </div>

    </form>
  </section>
</main>

<%- include('../rodape') %>
