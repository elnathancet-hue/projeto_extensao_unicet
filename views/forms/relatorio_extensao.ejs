<%- include('../cabecalho', { titulo: 'Relatorio de Extensao' }) %>

<%
  const p = projeto || {};
  const formatDate = (d) => {
    if (!d) return '---';
    try { return new Date(d).toLocaleDateString('pt-BR'); } catch(e) { return '---'; }
  };
%>

<main class="container my-5">
  <section class="card shadow p-4 p-md-5">

    <h1 class="fs-4 fw-bold mb-4 border-bottom pb-3">
      <i class="bi bi-file-earmark-text"></i> Relatorio de Extensao - <%= p.titulo || '' %>
    </h1>

    <form method="POST" action="/projeto_extensao/<%= p.id_projeto %>/relatorio">

      <!-- ===== DADOS DO PROJETO (readonly) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-info-circle"></i> Dados do Projeto</h5>

      <div class="row mb-3">
        <div class="col-md-6">
          <label class="form-label fw-semibold">Tipo de Extensao</label>
          <div class="form-control bg-light"><%= p.tipo_plano_nome || '---' %></div>
        </div>
        <div class="col-md-6">
          <label class="form-label fw-semibold">Titulo</label>
          <div class="form-control bg-light"><%= p.titulo || '---' %></div>
        </div>
      </div>

      <div class="row mb-3">
        <div class="col-md-4">
          <label class="form-label fw-semibold">Periodo</label>
          <div class="form-control bg-light">
            <%= formatDate(p.periodo_inicio) %> a <%= formatDate(p.periodo_fim) %>
          </div>
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold">Tipo de Acao</label>
          <div class="form-control bg-light">
            <%= (p.tiposAcao && p.tiposAcao.length > 0) ? p.tiposAcao.map(t => t.nome).join(', ') : '---' %>
          </div>
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold">Area Tematica</label>
          <div class="form-control bg-light"><%= p.area_tematica || '---' %></div>
        </div>
      </div>

      <div class="row mb-3">
        <div class="col-md-6">
          <label class="form-label fw-semibold">Linha Programatica</label>
          <div class="form-control bg-light">
            <%= (p.linhas && p.linhas.length > 0) ? p.linhas.map(l => l.nome).join(', ') : '---' %>
          </div>
        </div>
        <div class="col-md-6">
          <label class="form-label fw-semibold">Carga Horaria</label>
          <div class="form-control bg-light"><%= p.carga_horaria_total || '---' %> h</div>
        </div>
      </div>

      <% if (p.locais && p.locais.length > 0) { %>
      <div class="mb-3">
        <label class="form-label fw-semibold">Local de Execucao</label>
        <div class="form-control bg-light" style="height:auto; min-height:38px;">
          <% p.locais.forEach((loc, i) => { %>
            <%= loc.endereco %> - <%= loc.bairro %>, <%= loc.cidade %><%= i < p.locais.length - 1 ? '; ' : '' %>
          <% }) %>
        </div>
      </div>
      <% } %>

      <!-- ===== EQUIPE EXECUTORA (readonly) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-people"></i> Equipe Executora</h5>

      <div class="row mb-3">
        <div class="col-md-6">
          <label class="form-label fw-semibold">Coordenador</label>
          <div class="form-control bg-light"><%= p.coordenador_nome || '---' %></div>
        </div>
        <div class="col-md-6">
          <label class="form-label fw-semibold">Cursos</label>
          <div class="form-control bg-light">
            <%= (p.cursos && p.cursos.length > 0) ? p.cursos.map(c => c.nome_curso).join(', ') : '---' %>
          </div>
        </div>
      </div>

      <% if (p.pessoas && p.pessoas.length > 0) { %>
      <div class="mb-3">
        <label class="form-label fw-semibold">Professores / Tecnicos</label>
        <div class="form-control bg-light" style="height:auto; min-height:38px;">
          <% p.pessoas.forEach((pe, i) => { %>
            <%= pe.nome %> (<%= pe.papel %>)<%= i < p.pessoas.length - 1 ? ', ' : '' %>
          <% }) %>
        </div>
      </div>
      <% } %>

      <!-- ===== PUBLICO-ALVO (readonly) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-person-lines-fill"></i> Publico-Alvo</h5>
      <div class="mb-3">
        <div class="form-control bg-light"><%= p.publico_alvo_nome || '---' %></div>
      </div>

      <!-- ===== OBJETIVOS (readonly) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-bullseye"></i> Objetivos</h5>
      <div class="mb-3">
        <div class="form-control bg-light" style="height:auto; min-height:80px; white-space:pre-wrap;"><%= p.objetivo || '---' %></div>
      </div>

      <!-- ===== JUSTIFICATIVA (editavel) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-journal-text"></i> Justificativa</h5>
      <div class="mb-3">
        <textarea name="justificativa" class="form-control" rows="5" placeholder="Descreva a justificativa da acao..."><%= p.justificativa || '' %></textarea>
      </div>

      <!-- ===== METODOLOGIA (readonly) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-diagram-3"></i> Metodologia</h5>
      <div class="mb-3">
        <div class="form-control bg-light" style="height:auto; min-height:80px; white-space:pre-wrap;"><%= p.metodologia || '---' %></div>
      </div>

      <!-- ===== CRONOGRAMA / ATIVIDADES DESENVOLVIDAS (readonly) ===== -->
      <% if (p.cronograma && p.cronograma.length > 0) { %>
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-calendar-range"></i> Atividades Desenvolvidas</h5>
      <div class="table-responsive mb-3">
        <table class="table table-bordered table-striped">
          <thead class="table-light">
            <tr>
              <th>Atividade</th>
              <th>Inicio</th>
              <th>Fim</th>
            </tr>
          </thead>
          <tbody>
            <% p.cronograma.forEach(c => { %>
            <tr>
              <td><%= c.atividade || c.descricao || '' %></td>
              <td><%= formatDate(c.data_inicio || c.inicio) %></td>
              <td><%= formatDate(c.data_fim || c.fim) %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>

      <!-- ===== RESULTADOS ALCANCADOS (editavel) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-check2-circle"></i> Resultados Alcancados</h5>
      <div class="mb-3">
        <textarea name="resultados_alcancados" class="form-control" rows="5" placeholder="Descreva os resultados alcancados..."><%= p.resultados_alcancados || '' %></textarea>
      </div>

      <!-- ===== AVALIACAO DA COMUNIDADE (editavel) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-chat-left-text"></i> Avaliacao da Comunidade</h5>
      <div class="mb-3">
        <textarea name="avaliacao_comunidade" class="form-control" rows="5" placeholder="Descreva a avaliacao da comunidade sobre a acao..."><%= p.avaliacao_comunidade || '' %></textarea>
      </div>

      <!-- ===== AVALIACAO DA EQUIPE (editavel) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-clipboard-data"></i> Avaliacao da Equipe</h5>
      <div class="mb-3">
        <textarea name="avaliacao_equipe" class="form-control" rows="5" placeholder="Descreva a avaliacao da equipe executora sobre a acao..."><%= p.avaliacao_equipe || '' %></textarea>
      </div>

      <!-- ===== PRODUTOS GERADOS (editavel) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-box-seam"></i> Produtos Gerados</h5>
      <div class="mb-3">
        <textarea name="produtos_gerados" class="form-control" rows="5" placeholder="Liste os produtos gerados pela acao..."><%= p.produtos_gerados || '' %></textarea>
      </div>

      <!-- ===== ODS (editavel) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-globe2"></i> Vinculacao com os ODS</h5>
      <div class="mb-3">
        <textarea name="ods" class="form-control" rows="4" placeholder="Indique os Objetivos de Desenvolvimento Sustentavel (ODS) vinculados..."><%= p.ods || '' %></textarea>
      </div>

      <!-- ===== OBSERVACAO FINAL (editavel) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-pencil-square"></i> Observacao Final</h5>
      <div class="mb-3">
        <textarea name="observacao_final" class="form-control" rows="5" placeholder="Observacoes finais..."><%= p.observacao_final || 'Esta atividade de extensao foi desenvolvida em conformidade com a Resolucao CNE/CES n. 7, de 18 de dezembro de 2018, que estabelece as Diretrizes para a Extensao na Educacao Superior Brasileira.' %></textarea>
      </div>

      <!-- ===== ANEXOS (editavel) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-paperclip"></i> Anexos</h5>
      <div class="mb-3">
        <textarea name="anexos" class="form-control" rows="4" placeholder="Liste os anexos (fotos, listas de presenca, materiais, etc.)..."><%= p.anexos || '' %></textarea>
      </div>

      <!-- ===== BOTOES ===== -->
      <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary">
          <i class="bi bi-save"></i> Salvar
        </button>
        <a href="/projeto_extensao/<%= p.id_projeto %>/relatorio/pdf" class="btn btn-success" target="_blank">
          <i class="bi bi-filetype-pdf"></i> Baixar PDF
        </a>
        <a href="/projeto_extensao" class="btn btn-secondary">
          <i class="bi bi-arrow-left"></i> Voltar
        </a>
      </div>

    </form>
  </section>
</main>

<%- include('../rodape') %>