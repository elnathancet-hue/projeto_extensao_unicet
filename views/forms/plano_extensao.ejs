<%- include('../cabecalho', { titulo: 'Plano de Extensão' }) %>

<%
  const p = projeto || {};
  const formatDate = (d) => {
    if (!d) return '---';
    try { return new Date(d).toLocaleDateString('pt-BR'); } catch(e) { return '---'; }
  };
  const formatBR = (valor) => {
    const num = Number(valor);
    if (Number.isNaN(num)) return valor ?? '';
    return num.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  };
%>

<main class="container my-5">
  <section class="card shadow p-4 p-md-5">

    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
      <h1 class="fs-4 fw-bold mb-0">
        <i class="bi bi-file-earmark-text"></i> Plano de Extensão
      </h1>
      <div class="d-flex gap-2">
        <a href="/projeto_extensao/<%= p.id_projeto %>/plano/pdf" class="btn btn-sm btn-success" target="_blank">
          <i class="bi bi-filetype-pdf"></i> Baixar PDF
        </a>
        <a href="/projeto_extensao/<%= p.id_projeto %>/edit" class="btn btn-sm btn-outline-secondary">
          <i class="bi bi-pencil"></i> Editar Projeto
        </a>
      </div>
    </div>

    <!-- ===== TIPO DE EXTENSÃO ===== -->
    <div class="border rounded p-3 mb-3 bg-light">
      <span class="fw-bold" style="font-size:0.813rem">Tipo de Extensão:</span>
      <span style="font-size:0.813rem"><%= p.tipo_plano_nome || '---' %></span>
    </div>

    <!-- ===== I - IDENTIFICAÇÃO ===== -->
    <div class="border rounded p-3 mb-3">
      <h6 class="fw-bold mb-3">I - Identificação</h6>
      <table class="table table-sm mb-0" style="font-size:0.813rem">
        <tr><td class="fw-semibold" style="width:200px">Título</td><td><%= p.titulo || '---' %></td></tr>
        <tr><td class="fw-semibold">Linha Programática</td><td><%= (p.linhas && p.linhas.length) ? p.linhas.map(l => l.nome).join(', ') : '---' %></td></tr>
        <tr><td class="fw-semibold">Tipo de Ação</td><td><%= (p.tiposAcao && p.tiposAcao.length) ? p.tiposAcao.map(t => t.nome).join(', ') : '---' %></td></tr>
        <tr><td class="fw-semibold">Coordenador</td><td><%= p.coordenador_nome || '---' %></td></tr>
        <tr><td class="fw-semibold">Cursos Envolvidos</td><td><%= (p.cursos && p.cursos.length) ? p.cursos.map(c => c.nome_curso).join(', ') : '---' %></td></tr>
        <tr><td class="fw-semibold">Período</td><td><%= formatDate(p.periodo_inicio) %> a <%= formatDate(p.periodo_fim) %></td></tr>
        <tr><td class="fw-semibold">Carga Horária</td><td><%= p.carga_horaria_total || '---' %> horas</td></tr>
        <tr><td class="fw-semibold">Público-Alvo</td><td><%= p.publico_alvo_nome || '---' %></td></tr>
      </table>

      <!-- LOCAIS DO PROJETO (gerenciavel) -->
      <div class="mt-3 p-2 border rounded bg-white">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <span class="fw-semibold" style="font-size:0.813rem"><i class="bi bi-geo-alt"></i> Locais de Execução</span>
          <button type="button" class="btn btn-sm btn-outline-primary" style="font-size:0.688rem" onclick="document.getElementById('form-add-local').style.display = document.getElementById('form-add-local').style.display === 'none' ? 'block' : 'none'"><i class="bi bi-plus"></i> Adicionar Local</button>
        </div>
        <% if (p.locais && p.locais.length) { %>
        <table class="table table-sm table-bordered mb-2" style="font-size:0.75rem">
          <thead class="table-light"><tr><th>Endereço</th><th>Bairro</th><th>Cidade</th><th style="width:60px"></th></tr></thead>
          <tbody>
            <% p.locais.forEach(loc => { %>
            <tr>
              <td><%= loc.endereco || '' %></td>
              <td><%= loc.bairro || '' %></td>
              <td><%= loc.cidade || '' %></td>
              <td>
                <form method="POST" action="/projeto_extensao/<%= p.id_projeto %>/local/<%= loc.id_local %>/delete" onsubmit="return confirm('Desvincular este local do projeto?')">
                  <input type="hidden" name="from" value="plano">
                  <button type="submit" class="btn btn-sm btn-outline-danger" style="font-size:0.625rem; padding:1px 4px" title="Desvincular"><i class="bi bi-x-lg"></i></button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } else { %>
        <p class="text-muted mb-2" style="font-size:0.75rem"><i class="bi bi-info-circle"></i> Nenhum local vinculado.</p>
        <% } %>
        <div id="form-add-local" style="display:none; border-top:1px solid #dee2e6; padding-top:8px">
          <form method="POST" action="/projeto_extensao/<%= p.id_projeto %>/local" class="row g-2 align-items-end">
            <input type="hidden" name="from" value="plano">
            <div class="col-md-4"><input name="endereco" class="form-control form-control-sm" placeholder="Endereço" required style="font-size:0.75rem"></div>
            <div class="col-md-3"><input name="bairro" class="form-control form-control-sm" placeholder="Bairro" style="font-size:0.75rem"></div>
            <div class="col-md-2"><input name="cidade" class="form-control form-control-sm" placeholder="Cidade" style="font-size:0.75rem"></div>
            <div class="col-md-2"><input name="cep" class="form-control form-control-sm" placeholder="CEP" style="font-size:0.75rem"></div>
            <div class="col-md-1"><button type="submit" class="btn btn-sm btn-primary" style="font-size:0.688rem"><i class="bi bi-check-lg"></i></button></div>
          </form>
        </div>
      </div>

      <!-- INSTITUICOES DO PROJETO (gerenciavel) -->
      <div class="mt-3 p-2 border rounded bg-white">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <span class="fw-semibold" style="font-size:0.813rem"><i class="bi bi-building"></i> Instituições Parceiras</span>
          <button type="button" class="btn btn-sm btn-outline-primary" style="font-size:0.688rem" onclick="document.getElementById('form-add-inst').style.display = document.getElementById('form-add-inst').style.display === 'none' ? 'block' : 'none'"><i class="bi bi-plus"></i> Adicionar Instituição</button>
        </div>
        <% if (p.instituicoes && p.instituicoes.length) { %>
        <table class="table table-sm table-bordered mb-2" style="font-size:0.75rem">
          <thead class="table-light"><tr><th>Nome</th><th>Sigla</th><th>Tipo</th><th style="width:60px"></th></tr></thead>
          <tbody>
            <% p.instituicoes.forEach(inst => { %>
            <tr>
              <td><%= inst.nome || '' %></td>
              <td><%= inst.sigla || '' %></td>
              <td><%= inst.tipo || '' %></td>
              <td>
                <form method="POST" action="/projeto_extensao/<%= p.id_projeto %>/instituicao/<%= inst.id_instituicao %>/delete" onsubmit="return confirm('Desvincular esta instituição do projeto?')">
                  <input type="hidden" name="from" value="plano">
                  <button type="submit" class="btn btn-sm btn-outline-danger" style="font-size:0.625rem; padding:1px 4px" title="Desvincular"><i class="bi bi-x-lg"></i></button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } else { %>
        <p class="text-muted mb-2" style="font-size:0.75rem"><i class="bi bi-info-circle"></i> Nenhuma instituição vinculada.</p>
        <% } %>
        <div id="form-add-inst" style="display:none; border-top:1px solid #dee2e6; padding-top:8px">
          <form method="POST" action="/projeto_extensao/<%= p.id_projeto %>/instituicao" class="row g-2 align-items-end">
            <input type="hidden" name="from" value="plano">
            <div class="col-md-5"><input name="nome" class="form-control form-control-sm" placeholder="Nome da Instituição" required style="font-size:0.75rem"></div>
            <div class="col-md-3"><input name="sigla" class="form-control form-control-sm" placeholder="Sigla" style="font-size:0.75rem"></div>
            <div class="col-md-3"><input name="id_tipo_instituicao" type="number" class="form-control form-control-sm" placeholder="Tipo (ID)" style="font-size:0.75rem"></div>
            <div class="col-md-1"><button type="submit" class="btn btn-sm btn-primary" style="font-size:0.688rem"><i class="bi bi-check-lg"></i></button></div>
          </form>
        </div>
      </div>

      <% if (p.pessoas && p.pessoas.length) { %>
      <div class="mt-2">
        <span class="fw-semibold" style="font-size:0.813rem">Professores e Técnicos:</span>
        <span style="font-size:0.813rem"><% p.pessoas.forEach((pe, i) => { %><%= pe.nome %> (<%= pe.papel %>)<%= i < p.pessoas.length - 1 ? ', ' : '' %><% }) %></span>
      </div>
      <% } %>
      <div class="mt-2">
        <a href="/projeto_extensao/<%= p.id_projeto %>/edit" class="btn btn-sm btn-outline-primary" style="font-size:0.688rem"><i class="bi bi-pencil"></i> Editar dados do projeto</a>
      </div>
    </div>

    <!-- ===== II - OBJETIVOS ===== -->
    <div class="border rounded p-3 mb-3">
      <h6 class="fw-bold mb-2">II - Objetivo(s)</h6>
      <div style="font-size:0.813rem; white-space:pre-wrap; background:#f9fafb; padding:8px; border-radius:4px; min-height:40px"><%= p.objetivo || '---' %></div>
    </div>

    <!-- ===== III - METODOLOGIA ===== -->
    <div class="border rounded p-3 mb-3">
      <h6 class="fw-bold mb-2">III - Metodologia</h6>
      <div style="font-size:0.813rem; white-space:pre-wrap; background:#f9fafb; padding:8px; border-radius:4px; min-height:40px"><%= p.metodologia || '---' %></div>
    </div>

    <!-- ===== IV - CRONOGRAMA ===== -->
    <div class="border rounded p-3 mb-3">
      <div class="d-flex justify-content-between align-items-center mb-2">
        <h6 class="fw-bold mb-0">IV - Cronograma de Atividades</h6>
        <button type="button" class="btn btn-sm btn-outline-primary" style="font-size:0.688rem" onclick="document.getElementById('form-add-cronograma').style.display = document.getElementById('form-add-cronograma').style.display === 'none' ? 'block' : 'none'"><i class="bi bi-plus"></i> Adicionar Atividade</button>
      </div>
      <% if (p.cronograma && p.cronograma.length) { %>
      <table class="table table-sm table-bordered" style="font-size:0.75rem">
        <thead class="table-light"><tr><th>Nº</th><th>Etapa</th><th>Data</th><th>Hora</th><th>Local</th><th style="width:60px"></th></tr></thead>
        <tbody>
          <% p.cronograma.forEach(c => { %>
          <tr>
            <td><%= c.numero || '' %></td>
            <td><%= c.etapa || '' %></td>
            <td><%= formatDate(c.data) %></td>
            <td><%= c.hora || '' %></td>
            <td><%= c.local || '' %></td>
            <td>
              <form method="POST" action="/projeto_extensao/<%= p.id_projeto %>/cronograma/<%= c.id %>/delete" onsubmit="return confirm('Excluir esta atividade?')">
                <input type="hidden" name="from" value="plano">
                <button type="submit" class="btn btn-sm btn-outline-danger" style="font-size:0.625rem; padding:1px 4px" title="Excluir"><i class="bi bi-trash"></i></button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } else { %>
      <p class="text-muted text-center py-3" style="font-size:0.75rem"><i class="bi bi-info-circle"></i> Nenhuma atividade cadastrada. Clique em "Adicionar Atividade" para incluir.</p>
      <% } %>
      <div id="form-add-cronograma" style="display:none; border-top:1px solid #dee2e6; padding-top:8px; margin-top:8px">
        <form method="POST" action="/projeto_extensao/<%= p.id_projeto %>/cronograma" class="row g-2 align-items-end">
          <input type="hidden" name="from" value="plano">
          <div class="col-md-1"><label class="form-label" style="font-size:0.688rem">Nº</label><input name="numero" type="number" class="form-control form-control-sm" placeholder="1" required style="font-size:0.75rem"></div>
          <div class="col-md-3"><label class="form-label" style="font-size:0.688rem">Etapa</label><input name="etapa" class="form-control form-control-sm" placeholder="Descrição da atividade" required style="font-size:0.75rem"></div>
          <div class="col-md-2"><label class="form-label" style="font-size:0.688rem">Data</label><input name="data" type="date" class="form-control form-control-sm" style="font-size:0.75rem"></div>
          <div class="col-md-2"><label class="form-label" style="font-size:0.688rem">Hora</label><input name="hora" type="time" class="form-control form-control-sm" style="font-size:0.75rem"></div>
          <div class="col-md-3"><label class="form-label" style="font-size:0.688rem">Local</label><input name="local" class="form-control form-control-sm" placeholder="Sala, Auditório..." style="font-size:0.75rem"></div>
          <div class="col-md-1"><button type="submit" class="btn btn-sm btn-primary" style="font-size:0.688rem"><i class="bi bi-check-lg"></i> Salvar</button></div>
        </form>
      </div>
    </div>

    <!-- ===== V - CUSTOS ===== -->
    <div class="border rounded p-3 mb-3">
      <div class="d-flex justify-content-between align-items-center mb-2">
        <h6 class="fw-bold mb-0">V - Custos do Projeto</h6>
        <button type="button" class="btn btn-sm btn-outline-primary" style="font-size:0.688rem" onclick="document.getElementById('form-add-custo').style.display = document.getElementById('form-add-custo').style.display === 'none' ? 'block' : 'none'"><i class="bi bi-plus"></i> Adicionar Custo</button>
      </div>
      <% if (p.custos && p.custos.length) { %>
      <table class="table table-sm table-bordered" style="font-size:0.75rem">
        <thead class="table-light"><tr><th>Nº</th><th>Descrição</th><th>Qtd</th><th>V. Unit.</th><th>V. Total</th><th>Justificativa</th><th style="width:60px"></th></tr></thead>
        <tbody>
          <% let totalGeral = 0; %>
          <% p.custos.forEach((cu, idx) => { %>
          <% const vt = Number(cu.quantitativo || 0) * Number(cu.valor_unitario || 0); totalGeral += vt; %>
          <tr>
            <td><%= idx + 1 %></td>
            <td><%= cu.descricao || '' %></td>
            <td><%= cu.quantitativo || '' %></td>
            <td>R$ <%= formatBR(cu.valor_unitario) %></td>
            <td>R$ <%= formatBR(vt) %></td>
            <td><%= cu.justificativa || '' %></td>
            <td>
              <form method="POST" action="/projeto_extensao/<%= p.id_projeto %>/custo/<%= cu.Id %>/delete" onsubmit="return confirm('Excluir este custo?')">
                <input type="hidden" name="from" value="plano">
                <button type="submit" class="btn btn-sm btn-outline-danger" style="font-size:0.625rem; padding:1px 4px" title="Excluir"><i class="bi bi-trash"></i></button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
        <tfoot><tr class="table-light"><td colspan="4" style="text-align:right;font-weight:bold">Total:</td><td style="font-weight:bold">R$ <%= formatBR(totalGeral) %></td><td colspan="2"></td></tr></tfoot>
      </table>
      <% } else { %>
      <p class="text-muted text-center py-3" style="font-size:0.75rem"><i class="bi bi-info-circle"></i> Nenhum custo cadastrado. Clique em "Adicionar Custo" para incluir.</p>
      <% } %>
      <div id="form-add-custo" style="display:none; border-top:1px solid #dee2e6; padding-top:8px; margin-top:8px">
        <form method="POST" action="/projeto_extensao/<%= p.id_projeto %>/custo" class="row g-2 align-items-end">
          <input type="hidden" name="from" value="plano">
          <div class="col-md-3"><label class="form-label" style="font-size:0.688rem">Descrição</label><input name="descricao" class="form-control form-control-sm" placeholder="Descrição da despesa" required style="font-size:0.75rem"></div>
          <div class="col-md-2"><label class="form-label" style="font-size:0.688rem">Quantidade</label><input name="quantitativo" type="number" class="form-control form-control-sm" placeholder="1" required style="font-size:0.75rem"></div>
          <div class="col-md-2"><label class="form-label" style="font-size:0.688rem">Valor Unitário</label><input name="valor_unitario" type="number" step="0.01" class="form-control form-control-sm" placeholder="0.00" required style="font-size:0.75rem"></div>
          <div class="col-md-3"><label class="form-label" style="font-size:0.688rem">Justificativa</label><input name="justificativa" class="form-control form-control-sm" placeholder="Justificativa" style="font-size:0.75rem"></div>
          <div class="col-md-2"><button type="submit" class="btn btn-sm btn-primary" style="font-size:0.688rem"><i class="bi bi-check-lg"></i> Salvar</button></div>
        </form>
      </div>
    </div>

    <!-- ===== FORM DO PLANO (campos editáveis) ===== -->
    <form method="POST" action="/projeto_extensao/<%= p.id_projeto %>/plano">

      <!-- ===== VI - RESULTADOS ESPERADOS (editável) ===== -->
      <div class="border rounded p-3 mb-3">
        <h6 class="fw-bold mb-2">VI - Resultados Esperados</h6>
        <p class="text-muted" style="font-size:0.7rem;margin-bottom:6px">Descreva os resultados esperados com base nos objetivos do plano de extensão.</p>
        <textarea name="resultados_esperados" class="form-control form-control-sm" rows="4"><%= p.resultados_esperados || '' %></textarea>
      </div>

      <!-- ===== VII - AVALIAÇÃO (editável) ===== -->
      <div class="border rounded p-3 mb-3">
        <h6 class="fw-bold mb-2">VII - Avaliação</h6>
        <p class="text-muted" style="font-size:0.7rem;margin-bottom:6px">Descreva a forma de avaliação: participação, desempenho e produção dos resultados.</p>
        <textarea name="avaliacao_descricao" class="form-control form-control-sm" rows="4"><%= p.avaliacao_descricao || '' %></textarea>
      </div>

      <!-- ===== IX - REFERÊNCIAS (editável) ===== -->
      <div class="border rounded p-3 mb-3">
        <h6 class="fw-bold mb-2">IX - Referências</h6>
        <p class="text-muted" style="font-size:0.7rem;margin-bottom:6px">Seguir a NBR 6023/2018 (ABNT)</p>
        <textarea name="referencias" class="form-control form-control-sm" rows="4"><%= p.referencias || '' %></textarea>
      </div>

      <!-- ===== AÇÕES ===== -->
      <div class="d-flex gap-2 mt-3">
        <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-check-lg"></i> Salvar</button>
        <a href="/projeto_extensao" class="btn btn-secondary btn-sm"><i class="bi bi-arrow-left"></i> Voltar</a>
      </div>

    </form>
  </section>
</main>

<%- include('../rodape') %>
