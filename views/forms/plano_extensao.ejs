<%- include('../cabecalho', { titulo: 'Plano de Extensão' }) %>

<%
  const p = projeto || {};
  const formatDate = (d) => {
    if (!d) return '---';
    try { return new Date(d).toLocaleDateString('pt-BR'); } catch(e) { return '---'; }
  };
  const formatBR = (valor) => {
    const num = Number(valor);
    if (Number.isNaN(num)) return valor ?? '';
    return num.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  };
%>

<main class="container my-5">
  <section class="card shadow p-4 p-md-5">

    <h1 class="fs-4 fw-bold mb-4 border-bottom pb-3">
      <i class="bi bi-file-earmark-text"></i> Plano de Extensão - <%= p.titulo || '' %>
    </h1>

    <form method="POST" action="/projeto_extensao/<%= p.id_projeto %>/plano">

      <!-- ===== DADOS DO PROJETO (readonly) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-info-circle"></i> Dados do Projeto</h5>

      <div class="row mb-3">
        <div class="col-md-6">
          <label class="form-label fw-semibold">Tipo de Extensão</label>
          <div class="form-control bg-light"><%= p.tipo_plano_nome || '---' %></div>
        </div>
        <div class="col-md-6">
          <label class="form-label fw-semibold">Título</label>
          <div class="form-control bg-light"><%= p.titulo || '---' %></div>
        </div>
      </div>

      <div class="row mb-3">
        <div class="col-md-6">
          <label class="form-label fw-semibold">Linha Programática</label>
          <div class="form-control bg-light">
            <%= (p.linhas && p.linhas.length > 0) ? p.linhas.map(l => l.nome).join(', ') : '---' %>
          </div>
        </div>
        <div class="col-md-6">
          <label class="form-label fw-semibold">Tipo de Ação</label>
          <div class="form-control bg-light">
            <%= (p.tiposAcao && p.tiposAcao.length > 0) ? p.tiposAcao.map(t => t.nome).join(', ') : '---' %>
          </div>
        </div>
      </div>

      <div class="row mb-3">
        <div class="col-md-6">
          <label class="form-label fw-semibold">Coordenador</label>
          <div class="form-control bg-light"><%= p.coordenador_nome || '---' %></div>
        </div>
        <div class="col-md-6">
          <label class="form-label fw-semibold">Cursos</label>
          <div class="form-control bg-light">
            <%= (p.cursos && p.cursos.length > 0) ? p.cursos.map(c => c.nome_curso).join(', ') : '---' %>
          </div>
        </div>
      </div>

      <% if (p.pessoas && p.pessoas.length > 0) { %>
      <div class="mb-3">
        <label class="form-label fw-semibold">Professores / Técnicos</label>
        <div class="form-control bg-light" style="height:auto; min-height:38px;">
          <% p.pessoas.forEach((pe, i) => { %>
            <%= pe.nome %> (<%= pe.papel %>)<%= i < p.pessoas.length - 1 ? ', ' : '' %>
          <% }) %>
        </div>
      </div>
      <% } %>

      <div class="row mb-3">
        <div class="col-md-4">
          <label class="form-label fw-semibold">Período</label>
          <div class="form-control bg-light">
            <%= formatDate(p.periodo_inicio) %> a <%= formatDate(p.periodo_fim) %>
          </div>
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold">Carga Horária</label>
          <div class="form-control bg-light"><%= p.carga_horaria_total || '---' %> h</div>
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold">Público-Alvo</label>
          <div class="form-control bg-light"><%= p.publico_alvo_nome || '---' %></div>
        </div>
      </div>

      <% if (p.locais && p.locais.length > 0) { %>
      <div class="mb-3">
        <label class="form-label fw-semibold">Local de Execução</label>
        <div class="form-control bg-light" style="height:auto; min-height:38px;">
          <% p.locais.forEach((loc, i) => { %>
            <%= loc.endereco %> - <%= loc.bairro %>, <%= loc.cidade %><%= i < p.locais.length - 1 ? '; ' : '' %>
          <% }) %>
        </div>
      </div>
      <% } %>

      <% if (p.instituicoes && p.instituicoes.length > 0) { %>
      <div class="mb-3">
        <label class="form-label fw-semibold">Instituições Parceiras</label>
        <div class="form-control bg-light" style="height:auto; min-height:38px;">
          <% p.instituicoes.forEach((inst, i) => { %>
            <%= inst.nome %> (<%= inst.sigla %> - <%= inst.tipo %>)<%= i < p.instituicoes.length - 1 ? ', ' : '' %>
          <% }) %>
        </div>
      </div>
      <% } %>

      <!-- ===== II - OBJETIVOS (readonly) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-bullseye"></i> II - Objetivo(s)</h5>
      <div class="mb-3">
        <div class="form-control bg-light" style="height:auto; min-height:80px; white-space:pre-wrap;"><%= p.objetivo || '---' %></div>
      </div>

      <!-- ===== III - METODOLOGIA (readonly) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-diagram-3"></i> III - Metodologia</h5>
      <div class="mb-3">
        <div class="form-control bg-light" style="height:auto; min-height:80px; white-space:pre-wrap;"><%= p.metodologia || '---' %></div>
      </div>

      <!-- ===== IV - CRONOGRAMA DE ATIVIDADES (readonly) ===== -->
      <% if (p.cronograma && p.cronograma.length > 0) { %>
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-calendar-range"></i> IV - Cronograma de Atividades</h5>
      <div class="table-responsive mb-3">
        <table class="table table-bordered table-striped">
          <thead class="table-light">
            <tr>
              <th>N&#186;</th>
              <th>Etapa</th>
              <th>Data</th>
              <th>Hora</th>
              <th>Local</th>
            </tr>
          </thead>
          <tbody>
            <% p.cronograma.forEach(c => { %>
            <tr>
              <td><%= c.numero || '' %></td>
              <td><%= c.etapa || '' %></td>
              <td><%= formatDate(c.data) %></td>
              <td><%= c.hora || '' %></td>
              <td><%= c.local || '' %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>

      <!-- ===== V - CUSTOS DO PROJETO (readonly) ===== -->
      <% if (p.custos && p.custos.length > 0) { %>
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-currency-dollar"></i> V - Custos do Projeto</h5>
      <div class="table-responsive mb-3">
        <table class="table table-bordered table-striped">
          <thead class="table-light">
            <tr>
              <th>Descrição</th>
              <th>Qtd</th>
              <th>Valor Unit.</th>
              <th>Valor Total</th>
              <th>Justificativa</th>
              <th>Fonte</th>
            </tr>
          </thead>
          <tbody>
            <% let totalGeral = 0; %>
            <% p.custos.forEach(cu => { %>
              <% const vt = Number(cu.quantitativo || 0) * Number(cu.valor_unitario || 0); totalGeral += vt; %>
            <tr>
              <td><%= cu.descricao || '' %></td>
              <td><%= cu.quantitativo || '' %></td>
              <td>R$ <%= formatBR(cu.valor_unitario) %></td>
              <td>R$ <%= formatBR(vt) %></td>
              <td><%= cu.justificativa || '' %></td>
              <td><%= cu.fonte_recurso || '' %></td>
            </tr>
            <% }) %>
          </tbody>
          <tfoot>
            <tr class="table-light fw-bold">
              <td colspan="3" class="text-end">Total Geral:</td>
              <td>R$ <%= formatBR(totalGeral) %></td>
              <td colspan="2"></td>
            </tr>
          </tfoot>
        </table>
      </div>
      <% } %>

      <!-- ===== VI - RESULTADOS ESPERADOS (editavel) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-check2-circle"></i> VI - Resultados Esperados</h5>
      <div class="mb-3">
        <p class="text-muted" style="font-size:0.7rem;margin-bottom:6px">Descreva os resultados esperados com base nos objetivos do plano de extensão.</p>
        <textarea name="resultados_esperados" class="form-control" rows="5" placeholder="Descreva os resultados esperados..."><%= p.resultados_esperados || '' %></textarea>
      </div>

      <!-- ===== VII - AVALIAÇÃO (editavel) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-clipboard-data"></i> VII - Avaliação</h5>
      <div class="mb-3">
        <p class="text-muted" style="font-size:0.7rem;margin-bottom:6px">Descreva a forma de avaliação: participação, desempenho e produção dos resultados.</p>
        <textarea name="avaliacao_descricao" class="form-control" rows="5" placeholder="Descreva o processo de avaliação..."><%= p.avaliacao_descricao || '' %></textarea>
      </div>

      <!-- ===== IX - REFERÊNCIAS (editavel) ===== -->
      <h5 class="fw-bold mt-4 mb-3"><i class="bi bi-book"></i> IX - Referências</h5>
      <div class="mb-3">
        <p class="text-muted" style="font-size:0.7rem;margin-bottom:6px">Seguir a NBR 6023/2018 (ABNT)</p>
        <textarea name="referencias" class="form-control" rows="5" placeholder="Liste as referências bibliográficas..."><%= p.referencias || '' %></textarea>
      </div>

      <!-- ===== BOTÕES ===== -->
      <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-sm btn-primary">
          <i class="bi bi-save"></i> Salvar
        </button>
        <a href="/projeto_extensao/<%= p.id_projeto %>/plano/pdf" class="btn btn-sm btn-success" target="_blank">
          <i class="bi bi-filetype-pdf"></i> Baixar PDF
        </a>
        <a href="/projeto_extensao" class="btn btn-sm btn-secondary">
          <i class="bi bi-arrow-left"></i> Voltar
        </a>
      </div>

    </form>
  </section>
</main>

<%- include('../rodape') %>