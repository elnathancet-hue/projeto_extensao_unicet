
<%- include('../cabecalho', { titulo: isEdit ? 'Editar Instituicao' : 'Cadastrar Instituicao' }) %>

<% const registro = typeof instituicao !== 'undefined' ? instituicao : null; %>
<% const registroId = registro && registro['id_instituicao']; %>
<main id="conteudo-principal-form" class="container my-5">
  <section class="card shadow p-4 p-md-5">
    <h1 class="fs-4 fw-bold mb-4 border-bottom pb-3">
      <%= isEdit ? 'Editar instituicao' : 'Cadastrar instituicao' %>
    </h1>
    <form method="POST" action="<%= isEdit ? '/instituicao/' + registroId + '/edit' : '/instituicao/cadastrar' %>">

      <% if (isEdit) { %>
        <div class="mb-3">
          <label for="campo-id_instituicao" class="form-label">Id Instituição</label>
          <input
            id="campo-id_instituicao"
            name="id_instituicao"
            class="form-control bg-light"
            value="<%= registro && registro['id_instituicao'] != null ? registro['id_instituicao'] : '' %>"
            readonly
          >
        </div>
      <% } else { %>
        <!-- id_instituicao é auto incrementado no banco -->
        <input type="hidden" name="id_instituicao" value="">
      <% } %>

      <div class="mb-3">
        <label for="campo-nome" class="form-label">Nome</label>
        <input
          id="campo-nome"
          name="nome"
          class="form-control"
          value="<%= registro && registro['nome'] != null ? registro['nome'] : '' %>"
          placeholder="Nome"
          required
        >
      </div>

      <div class="mb-3">
        <label for="campo-sigla" class="form-label">Sigla</label>
        <input
          id="campo-sigla"
          name="sigla"
          class="form-control"
          value="<%= registro && registro['sigla'] != null ? registro['sigla'] : '' %>"
          placeholder="Sigla"
          required
        >
      </div>

      <div class="mb-3">
        <label for="campo-id_tipo_instituicao" class="form-label">Tipo de Instituição</label>
        <select
          id="campo-id_tipo_instituicao"
          name="id_tipo_instituicao"
          class="form-select"
          required
        >
          <option value="">Selecione o Tipo de Instituição</option>
          <% if (typeof tipos !== 'undefined' && tipos.length > 0) { %>
            <% tipos.forEach(t => { %>
              <option value="<%= t.id_tipo_instituicao %>" <%= (registro && registro.id_tipo_instituicao == t.id_tipo_instituicao) ? 'selected' : '' %>>
                <%= t.descricao %>
              </option>
            <% }) %>
          <% } %>
        </select>
        <% if (typeof tipos !== 'undefined' && tipos.length === 0) { %>
          <div class="form-text text-danger mt-1">Nenhum Tipo de Instituição cadastrado no sistema. Por favor, registre um antes.</div>
        <% } %>
      </div>
      <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary">
          <%= isEdit ? 'Salvar alterações' : 'Cadastrar' %>
        </button>
        <a href="/configuracoes#secao-cadastro" class="btn btn-secondary btn-sm">Voltar</a>
      </div>
    </form>

    <% if (isEdit && registroId) { %>
    <form method="POST" action="/instituicao/<%= registroId %>/delete" class="mt-3">
      <button type="submit" class="btn btn-danger">Excluir</button>
    </form>
    <% } %>
  </section>
</main>
<%- include('../rodape') %>