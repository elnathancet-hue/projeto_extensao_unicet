<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Times New Roman', Times, serif;
      font-size: 12pt;
      color: #000;
      line-height: 1.5;
      padding: 20px 40px;
    }
    .header {
      text-align: center;
      border-bottom: 2px solid #333;
      padding-bottom: 10px;
      margin-bottom: 20px;
    }
    .header img { height: 50px; }
    .header h2 {
      font-size: 10pt;
      color: #666;
      margin: 4px 0;
      font-weight: normal;
    }
    .title {
      text-align: center;
      font-size: 14pt;
      font-weight: bold;
      margin: 20px 0;
      text-transform: uppercase;
    }
    .section-title {
      font-weight: bold;
      font-size: 12pt;
      margin: 16px 0 8px;
      border-bottom: 1px solid #ccc;
      padding-bottom: 4px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin: 8px 0;
      font-size: 11pt;
    }
    th, td {
      border: 1px solid #999;
      padding: 6px 8px;
      text-align: left;
    }
    th {
      background: #f0f0f0;
      font-weight: bold;
    }
    .field-row {
      display: flex;
      margin-bottom: 4px;
    }
    .field-label {
      font-weight: bold;
      min-width: 180px;
    }
    .field-value {
      margin-bottom: 8px;
    }
    .text-block {
      margin: 4px 0 12px;
      text-align: justify;
      white-space: pre-wrap;
    }
    .signature-line {
      border-bottom: 1px solid #000;
      width: 300px;
      margin: 40px auto 4px;
    }
    .signature-label {
      text-align: center;
      font-size: 10pt;
    }
    .text-right { text-align: right; }
    .fw-bold { font-weight: bold; }
    .mt-20 { margin-top: 20px; }
    @media print {
      body { padding: 0; }
    }
  </style>
</head>
<body>

<%
  const p = projeto || {};
  const formatDate = (d) => {
    if (!d) return '___/___/______';
    try {
      const dt = new Date(d);
      const dd = String(dt.getDate()).padStart(2, '0');
      const mm = String(dt.getMonth() + 1).padStart(2, '0');
      const yyyy = dt.getFullYear();
      return dd + '/' + mm + '/' + yyyy;
    } catch(e) { return '___/___/______'; }
  };
  const formatBR = (valor) => {
    const num = Number(valor);
    if (Number.isNaN(num)) return valor ?? '0,00';
    return num.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  };
  const safe = (val) => val || '___';
%>

<!-- CABECALHO -->
<div class="header">
  <% if (typeof logoSrc !== 'undefined' && logoSrc) { %>
    <img src="<%= logoSrc %>" alt="UNI-CET">
  <% } %>
  <h2>CENTRO DE EDUCAÇÃO TECNOLÓGICA DE TERESINA - CET</h2>
  <h2>CENTRO UNIVERSITÁRIO TECNOLÓGICO DE TERESINA - UNI-CET</h2>
</div>

<div class="title">PLANO DE ATIVIDADE DE EXTENSÃO</div>

<!-- TIPO DE EXTENSÃO -->
<div class="section-title">TIPO DE EXTENSÃO</div>
<p class="field-value"><%= safe(p.tipo_plano_nome) %></p>

<!-- I - IDENTIFICAÇÃO -->
<div class="section-title">I - IDENTIFICAÇÃO</div>
<table>
  <tr>
    <td class="field-label" style="width:35%">Título do Projeto</td>
    <td><%= safe(p.titulo) %></td>
  </tr>
  <tr>
    <td class="field-label">Coordenador(a)</td>
    <td><%= safe(p.coordenador_nome) %></td>
  </tr>
  <tr>
    <td class="field-label">Linha Programática</td>
    <td><%= (p.linhas && p.linhas.length > 0) ? p.linhas.map(l => l.nome).join(', ') : '___' %></td>
  </tr>
  <tr>
    <td class="field-label">Tipo de Ação</td>
    <td><%= (p.tiposAcao && p.tiposAcao.length > 0) ? p.tiposAcao.map(t => t.nome).join(', ') : '___' %></td>
  </tr>
  <tr>
    <td class="field-label">Cursos Envolvidos</td>
    <td><%= (p.cursos && p.cursos.length > 0) ? p.cursos.map(c => c.nome_curso).join(', ') : '___' %></td>
  </tr>
  <tr>
    <td class="field-label">Período de Execução</td>
    <td><%= formatDate(p.periodo_inicio) %> a <%= formatDate(p.periodo_fim) %></td>
  </tr>
  <tr>
    <td class="field-label">Carga Horária Total</td>
    <td><%= p.carga_horaria_total ? p.carga_horaria_total + ' horas' : '___' %></td>
  </tr>
  <tr>
    <td class="field-label">Público-Alvo</td>
    <td><%= safe(p.publico_alvo_nome) %></td>
  </tr>
  <% if (p.locais && p.locais.length > 0) { %>
  <tr>
    <td class="field-label">Local de Execução</td>
    <td>
      <% p.locais.forEach((loc, i) => { %>
        <%= loc.endereco %> - <%= loc.bairro %>, <%= loc.cidade %><%= i < p.locais.length - 1 ? '; ' : '' %>
      <% }) %>
    </td>
  </tr>
  <% } %>
  <% if (p.instituicoes && p.instituicoes.length > 0) { %>
  <tr>
    <td class="field-label">Instituições Parceiras</td>
    <td>
      <% p.instituicoes.forEach((inst, i) => { %>
        <%= inst.nome %> (<%= inst.sigla %> - <%= inst.tipo %>)<%= i < p.instituicoes.length - 1 ? '; ' : '' %>
      <% }) %>
    </td>
  </tr>
  <% } %>
</table>

<% if (p.pessoas && p.pessoas.length > 0) { %>
<div style="margin-top: 8px;">
  <span class="field-label">Equipe do Projeto:</span>
  <table>
    <thead>
      <tr>
        <th>Nome</th>
        <th>Função</th>
      </tr>
    </thead>
    <tbody>
      <% p.pessoas.forEach(pe => { %>
      <tr>
        <td><%= pe.nome %></td>
        <td><%= pe.papel %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<% } %>

<!-- II - OBJETIVOS -->
<div class="section-title">II - OBJETIVOS</div>
<div class="text-block"><%= safe(p.objetivo) %></div>

<!-- III - METODOLOGIA -->
<div class="section-title">III - METODOLOGIA</div>
<div class="text-block"><%= safe(p.metodologia) %></div>

<!-- IV - CRONOGRAMA DE ATIVIDADES E AÇÕES -->
<div class="section-title">IV - CRONOGRAMA DE ATIVIDADES E AÇÕES</div>
<% if (p.cronograma && p.cronograma.length > 0) { %>
<table>
  <thead>
    <tr>
      <th style="width:40px">Nº</th>
      <th>Etapa</th>
      <th style="width:90px">Data</th>
      <th style="width:60px">Hora</th>
      <th>Local</th>
    </tr>
  </thead>
  <tbody>
    <% p.cronograma.forEach(c => { %>
    <tr>
      <td><%= c.numero || '' %></td>
      <td><%= c.etapa || '' %></td>
      <td><%= formatDate(c.data) %></td>
      <td><%= c.hora || '' %></td>
      <td><%= c.local || '' %></td>
    </tr>
    <% }) %>
  </tbody>
</table>
<% } else { %>
<p>___</p>
<% } %>

<!-- V - CUSTOS DO PROJETO -->
<div class="section-title">V - CUSTOS DO PROJETO</div>
<% if (p.custos && p.custos.length > 0) { %>
<table>
  <thead>
    <tr>
      <th style="width:35px">Nº</th>
      <th>Descrição da Despesa</th>
      <th style="width:50px">Qtd</th>
      <th style="width:90px">Valor Unit. (R$)</th>
      <th style="width:90px">Valor Total (R$)</th>
      <th>Justificativa</th>
    </tr>
  </thead>
  <tbody>
    <% let totalGeral = 0; %>
    <% p.custos.forEach((cu, idx) => { %>
      <% const qtd = Number(cu.quantitativo || 0); const unit = Number(cu.valor_unitario || 0); const vt = qtd * unit; totalGeral += vt; %>
    <tr>
      <td><%= idx + 1 %></td>
      <td><%= cu.descricao || '' %></td>
      <td><%= cu.quantitativo || '' %></td>
      <td>R$ <%= formatBR(unit) %></td>
      <td>R$ <%= formatBR(vt) %></td>
      <td><%= cu.justificativa || '' %></td>
    </tr>
    <% }) %>
  </tbody>
  <tfoot>
    <tr>
      <td colspan="4" style="text-align:right; font-weight:bold;">Total Geral:</td>
      <td style="font-weight:bold;">R$ <%= formatBR(totalGeral) %></td>
      <td></td>
    </tr>
  </tfoot>
</table>
<% } else { %>
<p>___</p>
<% } %>

<!-- VI - RESULTADOS ESPERADOS -->
<div class="section-title">VI - RESULTADOS ESPERADOS</div>
<div class="text-block"><%= safe(p.resultados_esperados) %></div>

<!-- VII - AVALIAÇÃO -->
<div class="section-title">VII - AVALIAÇÃO</div>
<div class="text-block"><%= safe(p.avaliacao_descricao) %></div>

<!-- IX - REFERÊNCIAS -->
<div class="section-title">IX - REFERÊNCIAS</div>
<div class="text-block"><%= safe(p.referencias) %></div>

<!-- X - AUTENTICAÇÃO -->
<div class="section-title">X - AUTENTICAÇÃO</div>

<div class="mt-20">
  <p style="text-align:center; margin-bottom:4px;">Teresina, ______ de ____________________ de ________</p>
</div>

<div class="mt-20">
  <div class="signature-line"></div>
  <p class="signature-label">Docente responsável</p>
</div>

<div class="mt-20">
  <div class="signature-line"></div>
  <p class="signature-label">Coordenador(a) de Curso responsável</p>
</div>

<div style="margin-top:30px; padding:12px; border:1px solid #999; page-break-inside:avoid;">
  <p style="font-weight:bold; font-size:10pt; margin-bottom:4px;">PARECER TÉCNICO</p>
  <p style="font-weight:bold; font-size:9pt;">PRÓ-REITORIA DE PÓS-GRADUAÇÃO, PESQUISA, EXTENSÃO E CURSOS LIVRES</p>
  <p>PARECER: _______________________________________________________________</p>
  <p style="margin-top:8px;">Teresina, ______ de ____________________ de ________</p>
  <div class="signature-line"></div>
  <p class="signature-label">Assinatura</p>
</div>

<div style="margin-top:16px; padding:12px; border:1px solid #999; page-break-inside:avoid;">
  <p style="font-weight:bold; font-size:9pt;">PRÓ-REITORIA EXECUTIVA DE ADMINISTRAÇÃO, INOVAÇÃO E TECNOLOGIA</p>
  <p>PARECER: _______________________________________________________________</p>
  <p style="margin-top:8px;">Teresina, ______ de ____________________ de ________</p>
  <div class="signature-line"></div>
  <p class="signature-label">Assinatura</p>
</div>

<div style="margin-top:16px; padding:12px; border:1px solid #999; page-break-inside:avoid;">
  <p style="font-weight:bold; font-size:9pt;">PRÓ-REITORIA DE ENSINO DE GRADUAÇÃO E APRENDIZAGEM, CULTURA, RELAÇÃO COMUNITÁRIA E RESPONSABILIDADE SOCIAL</p>
  <p>PARECER: _______________________________________________________________</p>
  <p style="margin-top:8px;">Teresina, ______ de ____________________ de ________</p>
  <div class="signature-line"></div>
  <p class="signature-label">Assinatura</p>
</div>

<div style="margin-top:16px; padding:12px; border:1px solid #999; page-break-inside:avoid;">
  <p style="font-weight:bold; font-size:9pt;">GERÊNCIA DE PESQUISA, EXTENSÃO E CURSOS LIVRES</p>
  <p>PARECER: _______________________________________________________________</p>
  <p style="margin-top:8px;">Teresina, ______ de ____________________ de ________</p>
  <div class="signature-line"></div>
  <p class="signature-label">Assinatura</p>
</div>

<div style="margin-top:16px; padding:12px; border:1px solid #999; page-break-inside:avoid;">
  <p style="font-weight:bold; font-size:9pt;">COORDENADORIA DO NÚCLEO DE APOIO PEDAGÓGICO - NAP</p>
  <p>PARECER: _______________________________________________________________</p>
  <p style="margin-top:8px;">Teresina, ______ de ____________________ de ________</p>
  <div class="signature-line"></div>
  <p class="signature-label">Assinatura</p>
</div>

<div style="margin-top:16px; padding:12px; border:1px solid #999; page-break-inside:avoid;">
  <p style="font-weight:bold; font-size:9pt;">NÚCLEO DOCENTE ESTRUTURANTE – NDE</p>
  <p>PARECER: _______________________________________________________________</p>
  <p style="margin-top:8px;">Teresina, ______ de ____________________ de ________</p>
  <p style="margin-top:16px;">Assinaturas:</p>
  <div class="signature-line"></div>
  <div class="signature-line"></div>
  <div class="signature-line"></div>
  <div class="signature-line"></div>
  <div class="signature-line"></div>
</div>

<script>
  window.onload = function() { window.print(); };
</script>
</body>
</html>