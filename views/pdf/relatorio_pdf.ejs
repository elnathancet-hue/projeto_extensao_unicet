<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Times New Roman', Times, serif;
      font-size: 12pt;
      color: #000;
      line-height: 1.5;
      padding: 20px 40px;
    }
    .header {
      text-align: center;
      border-bottom: 2px solid #333;
      padding-bottom: 10px;
      margin-bottom: 20px;
    }
    .header img { height: 50px; }
    .header h2 {
      font-size: 10pt;
      color: #666;
      margin: 4px 0;
      font-weight: normal;
    }
    .title {
      text-align: center;
      font-size: 14pt;
      font-weight: bold;
      margin: 20px 0;
      text-transform: uppercase;
    }
    .section-title {
      font-weight: bold;
      font-size: 12pt;
      margin: 16px 0 8px;
      border-bottom: 1px solid #ccc;
      padding-bottom: 4px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin: 8px 0;
      font-size: 11pt;
    }
    th, td {
      border: 1px solid #999;
      padding: 6px 8px;
      text-align: left;
    }
    th {
      background: #f0f0f0;
      font-weight: bold;
    }
    .field-row {
      display: flex;
      margin-bottom: 4px;
    }
    .field-label {
      font-weight: bold;
      min-width: 180px;
    }
    .field-value {
      margin-bottom: 8px;
    }
    .text-block {
      margin: 4px 0 12px;
      text-align: justify;
      white-space: pre-wrap;
    }
    .signature-line {
      border-bottom: 1px solid #000;
      width: 300px;
      margin: 40px auto 4px;
    }
    .signature-label {
      text-align: center;
      font-size: 10pt;
    }
    .text-right { text-align: right; }
    .fw-bold { font-weight: bold; }
    .mt-20 { margin-top: 20px; }
    @media print {
      body { padding: 0; }
    }
  </style>
</head>
<body>

<%
  const p = projeto || {};
  const formatDate = (d) => {
    if (!d) return '___/___/______';
    try {
      const dt = new Date(d);
      const dd = String(dt.getDate()).padStart(2, '0');
      const mm = String(dt.getMonth() + 1).padStart(2, '0');
      const yyyy = dt.getFullYear();
      return dd + '/' + mm + '/' + yyyy;
    } catch(e) { return '___/___/______'; }
  };
  const safe = (val) => val || '___';
%>

<!-- CABECALHO -->
<div class="header">
  <% if (typeof logoSrc !== 'undefined' && logoSrc) { %>
    <img src="<%= logoSrc %>" alt="UNI-CET">
  <% } %>
  <h2>CENTRO DE EDUCAÇÃO TECNOLÓGICA DE TERESINA - CET</h2>
  <h2>CENTRO UNIVERSITÁRIO TECNOLÓGICO DE TERESINA - UNI-CET</h2>
</div>

<div class="title">RELATÓRIO DA ATIVIDADE DE EXTENSÃO</div>

<!-- TIPO DE EXTENSÃO -->
<div class="section-title">TIPO DE EXTENSÃO</div>
<p class="field-value"><%= safe(p.tipo_plano_nome) %></p>

<table>
  <tr>
    <td class="field-label" style="width:35%">Título</td>
    <td><%= safe(p.titulo) %></td>
  </tr>
  <tr>
    <td class="field-label">Período de Execução</td>
    <td><%= formatDate(p.periodo_inicio) %> a <%= formatDate(p.periodo_fim) %></td>
  </tr>
</table>

<!-- I - IDENTIFICAÇÃO DA AÇÃO -->
<div class="section-title">I - IDENTIFICAÇÃO DA AÇÃO</div>
<table>
  <tr>
    <td class="field-label" style="width:35%">Tipo de Ação</td>
    <td><%= (p.tiposAcao && p.tiposAcao.length > 0) ? p.tiposAcao.map(t => t.nome).join(', ') : '___' %></td>
  </tr>
  <tr>
    <td class="field-label">Área Temática</td>
    <td><%= safe(p.area_tematica) %></td>
  </tr>
  <tr>
    <td class="field-label">Linha Programática</td>
    <td><%= (p.linhas && p.linhas.length > 0) ? p.linhas.map(l => l.nome).join(', ') : '___' %></td>
  </tr>
  <tr>
    <td class="field-label">Cursos Envolvidos</td>
    <td><%= (p.cursos && p.cursos.length > 0) ? p.cursos.map(c => c.nome_curso).join(', ') : '___' %></td>
  </tr>
  <% if (p.locais && p.locais.length > 0) { %>
  <tr>
    <td class="field-label">Local de Execução</td>
    <td>
      <% p.locais.forEach((loc, i) => { %>
        <%= loc.endereco %> - <%= loc.bairro %>, <%= loc.cidade %><%= i < p.locais.length - 1 ? '; ' : '' %>
      <% }) %>
    </td>
  </tr>
  <% } %>
  <% if (p.instituicoes && p.instituicoes.length > 0) { %>
  <tr>
    <td class="field-label">Instituições Parceiras</td>
    <td>
      <% p.instituicoes.forEach((inst, i) => { %>
        <%= inst.nome %> (<%= inst.sigla %> - <%= inst.tipo %>)<%= i < p.instituicoes.length - 1 ? '; ' : '' %>
      <% }) %>
    </td>
  </tr>
  <% } %>
</table>

<!-- II - EQUIPE EXECUTORA -->
<div class="section-title">II - EQUIPE EXECUTORA</div>
<table>
  <tr>
    <td class="field-label" style="width:35%">Coordenador(a)</td>
    <td><%= safe(p.coordenador_nome) %></td>
  </tr>
</table>
<% if (p.pessoas && p.pessoas.length > 0) { %>
<div style="margin-top: 8px;">
  <table>
    <thead>
      <tr>
        <th>Nome</th>
        <th>Função</th>
      </tr>
    </thead>
    <tbody>
      <% p.pessoas.forEach(pe => { %>
      <tr>
        <td><%= pe.nome %></td>
        <td><%= pe.papel %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<% } %>

<!-- III - PÚBLICO-ALVO E ABRANGÊNCIA -->
<div class="section-title">III - PÚBLICO-ALVO E ABRANGÊNCIA</div>
<div class="text-block"><%= safe(p.publico_alvo_nome) %></div>

<!-- IV - OBJETIVOS DA AÇÃO -->
<div class="section-title">IV - OBJETIVOS DA AÇÃO</div>
<div class="text-block"><%= safe(p.objetivo) %></div>

<!-- V - JUSTIFICATIVA -->
<div class="section-title">V - JUSTIFICATIVA</div>
<div class="text-block"><%= safe(p.justificativa) %></div>

<!-- VI - METODOLOGIA -->
<div class="section-title">VI - METODOLOGIA</div>
<div class="text-block"><%= safe(p.metodologia) %></div>

<!-- VII - ATIVIDADES DESENVOLVIDAS -->
<div class="section-title">VII - ATIVIDADES DESENVOLVIDAS</div>
<% if (p.cronograma && p.cronograma.length > 0) { %>
<table>
  <thead>
    <tr>
      <th>Atividade</th>
      <th>Inicio</th>
      <th>Fim</th>
    </tr>
  </thead>
  <tbody>
    <% p.cronograma.forEach(c => { %>
    <tr>
      <td><%= c.atividade || c.descricao || '' %></td>
      <td><%= formatDate(c.data_inicio || c.inicio) %></td>
      <td><%= formatDate(c.data_fim || c.fim) %></td>
    </tr>
    <% }) %>
  </tbody>
</table>
<% } else { %>
<p>___</p>
<% } %>

<!-- VIII - RESULTADOS ALCANÇADOS -->
<div class="section-title">VIII - RESULTADOS ALCANÇADOS</div>
<div class="text-block"><%= safe(p.resultados_alcancados) %></div>

<!-- IX - AVALIAÇÃO DA AÇÃO -->
<div class="section-title">IX - AVALIAÇÃO DA AÇÃO</div>
<p class="fw-bold" style="margin-top:8px;">Avaliação da Comunidade:</p>
<div class="text-block"><%= safe(p.avaliacao_comunidade) %></div>
<p class="fw-bold">Avaliação da Equipe Executora:</p>
<div class="text-block"><%= safe(p.avaliacao_equipe) %></div>

<!-- X - PRODUTOS GERADOS -->
<div class="section-title">X - PRODUTOS GERADOS</div>
<div class="text-block"><%= safe(p.produtos_gerados) %></div>

<!-- XI - VINCULAÇÃO COM OS ODS -->
<div class="section-title">XI - VINCULAÇÃO COM OS ODS</div>
<div class="text-block"><%= safe(p.ods) %></div>

<!-- XII - CARGA HORÁRIA TOTAL -->
<div class="section-title">XII - CARGA HORÁRIA TOTAL</div>
<div class="text-block"><%= p.carga_horaria_total ? p.carga_horaria_total + ' horas' : '___' %></div>

<!-- XIII - OBSERVAÇÃO FINAL -->
<div class="section-title">XIII - OBSERVAÇÃO FINAL</div>
<div class="text-block"><%= safe(p.observacao_final) %></div>

<!-- XIV - AUTENTICAÇÃO -->
<div class="section-title">XIV - AUTENTICAÇÃO</div>

<div class="mt-20">
  <p style="text-align:center; margin-bottom:4px;">Teresina - PI, ______ de ____________________ de ________</p>
</div>

<div class="mt-20">
  <div class="signature-line"></div>
  <p class="signature-label"><%= safe(p.coordenador_nome) %></p>
  <p class="signature-label">Coordenador(a) do Projeto</p>
</div>

<div class="mt-20">
  <div class="signature-line"></div>
  <p class="signature-label">Coordenador(a) de Extensão</p>
</div>

<div class="mt-20">
  <div class="signature-line"></div>
  <p class="signature-label">Pró-Reitor(a) de Extensão</p>
</div>

<!-- XV - ANEXOS -->
<div class="section-title" style="margin-top:30px;">XV - ANEXOS</div>
<div class="text-block"><%= safe(p.anexos) %></div>

<script>
  window.onload = function() { window.print(); };
</script>
</body>
</html>