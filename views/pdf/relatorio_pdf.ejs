<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <title>Relatório da Atividade de Extensão</title>
  <style>
    /* ===== RESET ===== */
    * { margin: 0; padding: 0; box-sizing: border-box; }

    /* ===== PÁGINA A4 - ABNT NBR 14724 =====
       Margens: superior 3cm, inferior 2cm, esquerda 3cm, direita 2cm
       Fonte: Times New Roman 12pt, espaçamento 1.5 */
    @page {
      size: A4 portrait;
      margin: 3cm 2cm 2cm 3cm;
    }

    body {
      font-family: 'Times New Roman', Times, serif;
      font-size: 12pt;
      color: #000;
      line-height: 1.5;
      text-align: justify;
      background: #fff;
    }

    /* ===== CABEÇALHO INSTITUCIONAL ===== */
    .header {
      text-align: center;
      margin-bottom: 24pt;
      padding-bottom: 8pt;
      border-bottom: 1.5pt solid #000;
    }
    .header img {
      height: 60px;
      margin-bottom: 4pt;
    }
    .header-inst {
      font-size: 11pt;
      font-weight: bold;
      text-transform: uppercase;
      margin: 2pt 0;
    }

    /* ===== TÍTULO DO DOCUMENTO ===== */
    .doc-title {
      text-align: center;
      font-size: 14pt;
      font-weight: bold;
      text-transform: uppercase;
      margin: 24pt 0 18pt;
    }

    /* ===== SEÇÕES ===== */
    .section-title {
      font-size: 12pt;
      font-weight: bold;
      text-transform: uppercase;
      margin: 18pt 0 8pt;
      padding-bottom: 2pt;
      border-bottom: 0.5pt solid #000;
    }

    /* ===== TABELAS ===== */
    table {
      width: 100%;
      border-collapse: collapse;
      margin: 6pt 0 12pt;
      font-size: 11pt;
    }
    th, td {
      border: 0.5pt solid #000;
      padding: 4pt 6pt;
      text-align: left;
      vertical-align: top;
    }
    th {
      background: #f2f2f2;
      font-weight: bold;
      font-size: 10pt;
      text-transform: uppercase;
    }
    td.label-cell {
      font-weight: bold;
      width: 35%;
      background: #fafafa;
    }

    /* ===== BLOCOS DE TEXTO ===== */
    .text-block {
      text-align: justify;
      text-indent: 1.25cm;
      margin: 4pt 0 12pt;
      white-space: pre-wrap;
      word-wrap: break-word;
    }
    .text-block-no-indent {
      text-align: justify;
      margin: 4pt 0 12pt;
      white-space: pre-wrap;
      word-wrap: break-word;
    }

    /* ===== SUBTÍTULO DENTRO DE SEÇÃO ===== */
    .sub-title {
      font-weight: bold;
      font-size: 12pt;
      margin: 12pt 0 4pt;
    }

    /* ===== ASSINATURAS ===== */
    .signature-block {
      margin-top: 40pt;
      text-align: center;
      page-break-inside: avoid;
    }
    .signature-line {
      border-bottom: 0.5pt solid #000;
      width: 280pt;
      margin: 0 auto 4pt;
    }
    .signature-name {
      font-size: 11pt;
      font-weight: bold;
    }
    .signature-role {
      font-size: 10pt;
    }

    /* ===== DATA CENTRALIZADA ===== */
    .data-local {
      text-align: center;
      margin: 30pt 0 10pt;
      font-size: 12pt;
    }

    /* ===== IMPRESSÃO ===== */
    @media print {
      body { background: #fff; }
      .no-print { display: none; }
    }

    /* ===== PAGINAÇÃO ===== */
    .page-break {
      page-break-before: always;
    }
  </style>
</head>
<body>

<%
  const p = projeto || {};
  const formatDate = (d) => {
    if (!d) return '___/___/______';
    try {
      const dt = new Date(d);
      const dd = String(dt.getDate()).padStart(2, '0');
      const mm = String(dt.getMonth() + 1).padStart(2, '0');
      const yyyy = dt.getFullYear();
      return dd + '/' + mm + '/' + yyyy;
    } catch(e) { return '___/___/______'; }
  };
  const safe = (val) => val || '________________________________________';
%>

<!-- ===== CABEÇALHO INSTITUCIONAL ===== -->
<div class="header">
  <% if (typeof logoSrc !== 'undefined' && logoSrc) { %>
    <img src="<%= logoSrc %>" alt="UNI-CET">
  <% } %>
  <p class="header-inst">Centro de Educação Tecnológica de Teresina - CET</p>
  <p class="header-inst">Centro Universitário Tecnológico de Teresina - UNI-CET</p>
</div>

<!-- ===== TÍTULO ===== -->
<div class="doc-title">Relatório da Atividade de Extensão</div>

<!-- ===== TIPO DE EXTENSÃO ===== -->
<div class="section-title">Tipo de Extensão</div>
<p style="margin: 4pt 0 12pt;"><%= safe(p.tipo_plano_nome) %></p>

<table>
  <tr>
    <td class="label-cell">Título</td>
    <td><%= safe(p.titulo) %></td>
  </tr>
  <tr>
    <td class="label-cell">Período de Execução</td>
    <td><%= formatDate(p.periodo_inicio) %> a <%= formatDate(p.periodo_fim) %></td>
  </tr>
</table>

<!-- ===== I - IDENTIFICAÇÃO DA AÇÃO ===== -->
<div class="section-title">I - Identificação da Ação</div>
<table>
  <tr>
    <td class="label-cell">Tipo de Ação</td>
    <td><%= (p.tiposAcao && p.tiposAcao.length > 0) ? p.tiposAcao.map(t => t.nome).join(', ') : '___' %></td>
  </tr>
  <tr>
    <td class="label-cell">Linha Programática</td>
    <td><%= (p.linhas && p.linhas.length > 0) ? p.linhas.map(l => l.nome).join(', ') : '___' %></td>
  </tr>
  <tr>
    <td class="label-cell">Cursos Envolvidos</td>
    <td><%= (p.cursos && p.cursos.length > 0) ? p.cursos.map(c => c.nome_curso).join(', ') : '___' %></td>
  </tr>
  <% if (p.locais && p.locais.length > 0) { %>
  <tr>
    <td class="label-cell">Local de Execução</td>
    <td><% p.locais.forEach((loc, i) => { %><%= loc.endereco %> - <%= loc.bairro %>, <%= loc.cidade %><%= i < p.locais.length - 1 ? '; ' : '' %><% }) %></td>
  </tr>
  <% } %>
  <% if (p.instituicoes && p.instituicoes.length > 0) { %>
  <tr>
    <td class="label-cell">Instituições Parceiras</td>
    <td><% p.instituicoes.forEach((inst, i) => { %><%= inst.nome %> (<%= inst.sigla %> - <%= inst.tipo %>)<%= i < p.instituicoes.length - 1 ? '; ' : '' %><% }) %></td>
  </tr>
  <% } %>
</table>

<!-- ===== II - EQUIPE EXECUTORA ===== -->
<div class="section-title">II - Equipe Executora</div>
<table>
  <tr>
    <td class="label-cell">Coordenador(a)</td>
    <td><%= safe(p.coordenador_nome) %></td>
  </tr>
</table>
<% if (p.pessoas && p.pessoas.length > 0) { %>
<table>
  <thead>
    <tr>
      <th style="width:60%">Nome</th>
      <th>Função</th>
    </tr>
  </thead>
  <tbody>
    <% p.pessoas.forEach(pe => { %>
    <tr>
      <td><%= pe.nome %></td>
      <td><%= pe.papel %></td>
    </tr>
    <% }) %>
  </tbody>
</table>
<% } %>

<!-- ===== III - PÚBLICO-ALVO E ABRANGÊNCIA ===== -->
<div class="section-title">III - Público-Alvo e Abrangência</div>
<div class="text-block"><%= safe(p.publico_alvo_nome) %></div>

<!-- ===== IV - OBJETIVOS DA AÇÃO ===== -->
<div class="section-title">IV - Objetivos da Ação</div>
<div class="text-block"><%= safe(p.objetivo) %></div>

<!-- ===== V - JUSTIFICATIVA ===== -->
<div class="section-title">V - Justificativa</div>
<div class="text-block"><%= safe(p.justificativa) %></div>

<!-- ===== VI - METODOLOGIA ===== -->
<div class="section-title">VI - Metodologia</div>
<div class="text-block"><%= safe(p.metodologia) %></div>

<!-- ===== VII - ATIVIDADES DESENVOLVIDAS ===== -->
<div class="section-title">VII - Atividades Desenvolvidas</div>
<% if (p.cronograma && p.cronograma.length > 0) { %>
<table>
  <thead>
    <tr>
      <th style="width:30pt">Nº</th>
      <th>Etapa / Atividade</th>
      <th style="width:70pt">Data</th>
      <th style="width:50pt">Hora</th>
      <th>Local</th>
    </tr>
  </thead>
  <tbody>
    <% p.cronograma.forEach(c => { %>
    <tr>
      <td style="text-align:center"><%= c.numero || '' %></td>
      <td><%= c.etapa || '' %></td>
      <td style="text-align:center"><%= formatDate(c.data) %></td>
      <td style="text-align:center"><%= c.hora || '' %></td>
      <td><%= c.local || '' %></td>
    </tr>
    <% }) %>
  </tbody>
</table>
<% } else { %>
<p style="margin: 4pt 0 12pt;">Nenhuma atividade cadastrada.</p>
<% } %>

<!-- ===== VIII - RESULTADOS ALCANÇADOS ===== -->
<div class="section-title">VIII - Resultados Alcançados</div>
<div class="text-block"><%= safe(p.resultados_alcancados) %></div>

<!-- ===== IX - AVALIAÇÃO DA AÇÃO ===== -->
<div class="section-title">IX - Avaliação da Ação</div>

<p class="sub-title">Avaliação da Comunidade:</p>
<div class="text-block"><%= safe(p.avaliacao_comunidade) %></div>

<p class="sub-title">Avaliação da Equipe Executora:</p>
<div class="text-block"><%= safe(p.avaliacao_equipe) %></div>

<!-- ===== X - PRODUTOS GERADOS ===== -->
<div class="section-title">X - Produtos Gerados</div>
<div class="text-block"><%= safe(p.produtos_gerados) %></div>

<!-- ===== XI - VINCULAÇÃO COM OS ODS ===== -->
<div class="section-title">XI - Vinculação com os ODS</div>
<div class="text-block"><%= safe(p.ods) %></div>

<!-- ===== XII - CARGA HORÁRIA TOTAL ===== -->
<div class="section-title">XII - Carga Horária Total</div>
<p style="margin: 4pt 0 12pt;"><%= p.carga_horaria_total ? p.carga_horaria_total + ' horas' : '___' %></p>

<!-- ===== XIII - OBSERVAÇÃO FINAL ===== -->
<div class="section-title">XIII - Observação Final</div>
<div class="text-block"><%= safe(p.observacao_final) %></div>

<!-- ===== XIV - AUTENTICAÇÃO ===== -->
<div class="page-break"></div>
<div class="section-title">XIV - Autenticação</div>

<div class="data-local">
  Teresina - PI, ______ de ____________________ de ________
</div>

<!-- Assinatura do Coordenador -->
<div class="signature-block">
  <div class="signature-line"></div>
  <p class="signature-name"><%= safe(p.coordenador_nome) %></p>
  <p class="signature-role">Coordenador(a) do Projeto</p>
</div>

<!-- Assinatura do Coordenador de Extensão -->
<div class="signature-block">
  <div class="signature-line"></div>
  <p class="signature-role">Coordenador(a) de Extensão</p>
</div>

<!-- Assinatura do Pró-Reitor -->
<div class="signature-block">
  <div class="signature-line"></div>
  <p class="signature-role">Pró-Reitor(a) de Extensão</p>
</div>

<!-- ===== XV - ANEXOS ===== -->
<div class="section-title" style="margin-top:30pt;">XV - Anexos</div>
<div class="text-block-no-indent"><%= safe(p.anexos) %></div>

<script>
  window.onload = function() { window.print(); };
</script>
</body>
</html>
