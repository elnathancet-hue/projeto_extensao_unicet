<%- include('../cabecalho', { titulo: 'Cursos' }) %>

<main id="conteudo-principal-form" class="container my-5">
  <section id="secao-cadastro-projeto" class="card shadow p-4 p-md-5">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
      <h1 class="h4 mb-0">
        <i class="bi bi-book me-2"></i>Cursos Cadastrados
      </h1>
      <a href="/configuracoes#secao-cadastro" class="btn btn-primary btn-sm">
        <i class="bi bi-arrow-left"></i> Voltar ao Cadastro
      </a>
    </div>

    <% const f = typeof filters !== 'undefined' ? filters : {}; %>
    <form method="GET" action="/curso" class="row g-2 mb-3 align-items-end">
      <div class="col-md-4">
        <label class="form-label">Nome do Curso</label>
        <input type="text" name="nome_curso" class="form-control form-control-sm" placeholder="Buscar por nome..." value="<%= f.nome_curso || '' %>">
      </div>
      <div class="col-auto d-flex gap-2">
        <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search"></i> Buscar</button>
        <a href="/curso" class="btn btn-secondary btn-sm"><i class="bi bi-x-circle"></i> Limpar</a>
      </div>
    </form>

    <div id="form-feedback-message" class="alert d-none" role="alert"></div>

    <div class="table-responsive">
      <table class="table table-hover cfg-table">
        <thead class="table-light">
          <tr>
            <th style="width:50px">ID</th>
            <th>Nome Curso</th>
            <th style="width:80px">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (dados && dados.length) { %> <% dados.forEach(d => { %>
          <tr>
            <td>
              <span class="badge bg-secondary"><%= d.id_curso %></span>
            </td>
            <td><%= d.nome_curso %></td>
            <td>
              <div class="cfg-actions">
                <a href="/curso/<%= d.id_curso %>/edit" class="btn btn-sm btn-outline-secondary" title="Editar"><i class="bi bi-pencil"></i></a>
                <a href="/curso/<%= d.id_curso %>/delete" class="btn btn-sm btn-outline-danger" title="Excluir" onclick="return confirm('Excluir este curso?')"><i class="bi bi-trash"></i></a>
              </div>
            </td>
          <% }) %> <% } else { %>
          <tr>
            <td colspan="3" class="text-center py-4 text-muted">
              Nenhum curso encontrado.
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <div class="mt-3">
      <a href="/configuracoes#secao-cadastro" class="btn btn-secondary btn-sm"><i class="bi bi-arrow-left"></i> Voltar</a>
    </div>
  </section>
</main>

<%- include('../rodape') %>
