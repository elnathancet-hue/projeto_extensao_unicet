<%- include('../cabecalho', { titulo: 'Projetos Custo' }) %>

<% 
const formatBR = (valor) => {
  const num = Number(valor);
  if (Number.isNaN(num)) return valor ?? '0,00';
  return num.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}; 

let totalGeral = 0;
if (dados && dados.length > 0) {
  dados.forEach(d => {
    const qtd = Number(d.quantitativo) || 0;
    const unit = Number(d.valor_unitario) || 0;
    totalGeral += (qtd * unit);
  });
}
%>

<main id="conteudo-principal-form" class="container my-5">
  <section id="secao-cadastro-projeto" class="card shadow p-4 p-md-5">
    <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
      <i class="bi bi-cash-coin fs-4 me-2"></i>
      <h1 class="fs-4 fw-bold mb-0">Custos e Receitas</h1>
    </div>

    <% const f = typeof filters !== 'undefined' ? filters : {}; %>
    <!-- Filtro de Projeto -->
    <div class="bg-light p-3 rounded mb-4 border">
      <form method="GET" action="/projeto_custo/consultas/projeto_custo" id="formFiltroProjeto" class="row g-2 align-items-end">
        <div class="col-md-5">
          <label for="filtro_id_projeto" class="form-label fw-bold">Selecione o Projeto:</label>
          <select
            name="id_projeto"
            id="filtro_id_projeto"
            class="form-select form-select-sm"
          >
            <option value="">-- Exibir nenhum --</option>
            <% if (typeof projetos !== 'undefined' && projetos.length > 0) { %>
              <% projetos.forEach(p => { %>
                <option value="<%= p.id_projeto %>" <%= (typeof idProjetoSelecionado !== 'undefined' && idProjetoSelecionado == p.id_projeto) ? 'selected' : '' %>>
                  <%= p.titulo %>
                </option>
              <% }) %>
            <% } %>
          </select>
        </div>
        <div class="col-auto d-flex gap-2">
          <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search"></i> Filtrar</button>
          <a href="/projeto_custo/consultas/projeto_custo" class="btn btn-secondary btn-sm"><i class="bi bi-x-circle"></i> Limpar</a>
        </div>
      </form>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
      <span class="fw-semibold">
        <% if (typeof idProjetoSelecionado !== 'undefined' && idProjetoSelecionado) { %>
          Exibindo custos do projeto selecionado
        <% } else { %>
          Listagem de Custos
        <% } %>
      </span>
      <a href="/projeto_custo/forms/projeto_custo" class="btn btn-primary btn-sm"><i class="bi bi-plus-circle"></i> Novo Custo</a>
    </div>

    <div id="form-feedback-message" class="alert d-none" role="alert"></div>

    <div class="table-responsive">
      <table class="table table-striped table-hover align-middle">
        <thead class="table-light">
          <tr>
            <th>ID</th>
            <th>Projeto</th>
            <th>Descrição da Despesa</th>
            <th>Quantidade</th>
            <th>V. Unitário (R$)</th>
            <th>Valor Total (R$)</th>
            <th>Justificativa</th>
            <th>Fonte do Recurso</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (typeof idProjetoSelecionado === 'undefined' || !idProjetoSelecionado) { %>
            <tr>
              <td colspan="9" class="text-center py-4 text-muted">Selecione um projeto</td>
            </tr>
          <% } else if (dados && dados.length > 0) { %>
            <% dados.forEach(d => { 
                 const qtd = Number(d.quantitativo) || 0;
                 const unit = Number(d.valor_unitario) || 0;
                 const totalItem = qtd * unit;
            %>
              <tr>
                <td>
                  <span class="badge bg-secondary"><%= d.Id %></span>
                </td>
                <td><%= d.projeto_titulo || d.id_projeto || '-' %></td>
                <td><%= d.descricao || '-' %></td>
                <td><%= formatBR(d.quantitativo) %></td>
                <td><span class="badge bg-info text-dark">R$ <%= formatBR(d.valor_unitario) %></span></td>
                <td><strong>R$ <%= formatBR(totalItem) %></strong></td>
                <td><%= d.justificativa || '-' %></td>
                <td><%= d.fonte_recurso || '-' %></td>
                <td>
                  <a href="/projeto_custo/<%= d.Id %>/edit" class="btn btn-primary btn-sm" title="Editar">
                    <i class="bi bi-pencil"></i> Editar
                  </a>
                  <form action="/projeto_custo/<%= d.Id %>/delete" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-danger btn-sm" title="Excluir" onclick="return confirm('Tem certeza que deseja excluir este custo?')">
                      <i class="bi bi-trash"></i> Excluir
                    </button>
                  </form>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="9" class="text-center py-4 text-muted">Nenhum registro de custo encontrado para este projeto.</td>
            </tr>
          <% } %>
        </tbody>
        <tfoot class="table-dark">
          <tr>
            <td colspan="5" class="text-end fw-bold">Somatório Total:</td>
            <td class="fw-bold text-success fs-5">R$ <%= formatBR(totalGeral) %></td>
            <td colspan="3"></td>
          </tr>
        </tfoot>
      </table>
    </div>

    <div class="mt-3">
      <a href="/logo" class="btn btn-secondary"><i class="bi bi-arrow-left"></i>Voltar</a>
    </div>
  </section>
</main>

<%- include('../rodape') %>