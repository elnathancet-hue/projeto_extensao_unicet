<%- include('../cabecalho', { titulo: 'Consulta de Instituição' }) %>

<main id="conteudo-principal-form" class="container my-5">
  <section class="card shadow p-4 p-md-5">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
      <h1 class="h4 mb-0">
        <i class="bi bi-shop me-2"></i>Instituições
      </h1>
      <a href="/configuracoes#secao-cadastro" class="btn btn-primary btn-sm">
        <i class="bi bi-arrow-left"></i> Voltar ao Cadastro
      </a>
    </div>

    <% const f = typeof filters !== 'undefined' ? filters : {}; %>
    <form method="GET" action="/instituicao" class="row g-2 mb-3 align-items-end">
      <div class="col-md-3">
        <label class="form-label">Nome</label>
        <input type="text" name="nome" class="form-control form-control-sm" placeholder="Buscar por nome..." value="<%= f.nome || '' %>">
      </div>
      <div class="col-md-3">
        <label class="form-label">Tipo Instituição</label>
        <select name="id_tipo_instituicao" class="form-select form-select-sm">
          <option value="">Todos</option>
          <% if (typeof tiposInstituicao !== 'undefined' && tiposInstituicao) { %>
            <% tiposInstituicao.forEach(ti => { %>
              <option value="<%= ti.id_tipo_instituicao %>" <%= (f.id_tipo_instituicao == ti.id_tipo_instituicao) ? 'selected' : '' %>><%= ti.descricao %></option>
            <% }) %>
          <% } %>
        </select>
      </div>
      <div class="col-auto d-flex gap-2">
        <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search"></i> Buscar</button>
        <a href="/instituicao" class="btn btn-secondary btn-sm"><i class="bi bi-x-circle"></i> Limpar</a>
      </div>
    </form>

    <div class="table-responsive">
      <table class="table table-hover cfg-table">
        <thead class="table-light">
          <tr>
            <th style="width:50px">ID</th>
            <th>Nome</th>
            <th>Sigla</th>
            <th>Tipo</th>
            <th style="width:80px">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (dados && dados.length) { %>
            <% dados.forEach(d => { %>
              <tr>
                <td><span class="badge bg-secondary"><%= d.id_instituicao %></span></td>
                <td><%= d.nome %></td>
                <td><%= d.sigla %></td>
                <td><span class="badge bg-info"><%= d.tipo || '-' %></span></td>
                <td>
                  <div class="cfg-actions">
                    <a href="/instituicao/<%= d.id_instituicao %>/edit" class="btn btn-sm btn-outline-secondary" title="Editar"><i class="bi bi-pencil"></i></a>
                    <a href="/instituicao/<%= d.id_instituicao %>/delete" class="btn btn-sm btn-outline-danger" title="Excluir" onclick="return confirm('Excluir esta instituição?')"><i class="bi bi-trash"></i></a>
                  </div>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="5" class="text-center py-4 text-muted">Nenhuma instituição encontrada.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <div class="mt-3">
      <a href="/configuracoes#secao-cadastro" class="btn btn-secondary btn-sm"><i class="bi bi-arrow-left"></i> Voltar</a>
    </div>
  </section>
</main>

<%- include('../rodape') %>
