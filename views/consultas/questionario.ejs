<%- include('../cabecalho', { titulo: 'Questionários de Impacto' }) %>

<%
  const p = (typeof projeto !== 'undefined') ? projeto : {};
  const r = (typeof resumo !== 'undefined') ? resumo : { total: 0 };
  const id = (typeof idProjeto !== 'undefined') ? idProjeto : '';
%>

<main class="container my-5">
  <section class="card shadow p-4 p-md-5">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
      <div>
        <h1 class="fs-4 fw-bold mb-1"><i class="bi bi-clipboard-check me-2"></i>Questionários de Impacto</h1>
        <p class="text-muted mb-0" style="font-size:0.8rem"><%= p.titulo || '' %></p>
      </div>
      <a href="/projeto_extensao/<%= id %>/questionarios/novo" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-circle"></i> Novo Questionário
      </a>
    </div>

    <!-- Resumo -->
    <% if (r.total > 0) { %>
    <div class="row g-3 mb-4">
      <div class="col-md-4">
        <div class="card bg-light p-3">
          <h6 class="fw-bold mb-2" style="font-size:0.8rem"><i class="bi bi-people"></i> Total de Respostas</h6>
          <span class="fs-3 fw-bold text-primary"><%= r.total %></span>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card bg-light p-3">
          <h6 class="fw-bold mb-2" style="font-size:0.8rem"><i class="bi bi-star"></i> Avaliação do Conteúdo</h6>
          <% if (r.avalCounts) { %>
            <% Object.entries(r.avalCounts).sort((a,b) => b[1]-a[1]).forEach(([k,v]) => { %>
              <div class="d-flex justify-content-between" style="font-size:0.8rem">
                <span><%= k %></span>
                <strong><%= Math.round(v/r.total*100) %>%</strong>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card bg-light p-3">
          <h6 class="fw-bold mb-2" style="font-size:0.8rem"><i class="bi bi-check2-circle"></i> Atendeu Expectativas</h6>
          <% if (r.expCounts) { %>
            <% Object.entries(r.expCounts).sort((a,b) => b[1]-a[1]).forEach(([k,v]) => { %>
              <div class="d-flex justify-content-between" style="font-size:0.8rem">
                <span><%= k %></span>
                <strong><%= Math.round(v/r.total*100) %>%</strong>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>
    </div>
    <% } %>

    <!-- Tabela -->
    <div class="table-responsive">
      <table class="table table-hover">
        <thead class="table-light">
          <tr>
            <th style="width:40px">#</th>
            <th>Data</th>
            <th>Faixa Etária</th>
            <th>Escolaridade</th>
            <th>Avaliação</th>
            <th>Expectativas</th>
            <th style="width:100px">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (dados && dados.length) { %>
            <% dados.forEach((q, idx) => { %>
              <tr>
                <td><span class="badge bg-secondary"><%= idx + 1 %></span></td>
                <td style="font-size:0.8rem"><%= q.data_realizacao ? new Date(q.data_realizacao).toLocaleDateString('pt-BR') : '-' %></td>
                <td style="font-size:0.8rem"><%= q.faixa_etaria || '-' %></td>
                <td style="font-size:0.8rem"><%= q.escolaridade || '-' %></td>
                <td>
                  <% const avalColors = { Excelente:'success', Bom:'info', Regular:'warning', Ruim:'danger', 'Péssimo':'danger' }; %>
                  <span class="badge bg-<%= avalColors[q.aval_conteudo] || 'secondary' %>" style="font-size:0.75rem"><%= q.aval_conteudo || '-' %></span>
                </td>
                <td style="font-size:0.8rem"><%= q.expectativas || '-' %></td>
                <td>
                  <div class="d-flex gap-1">
                    <a href="/projeto_extensao/<%= id %>/questionarios/<%= q.id %>/edit" class="btn btn-sm btn-outline-secondary" style="font-size:0.75rem; padding:2px 6px" title="Editar"><i class="bi bi-pencil"></i></a>
                    <form method="POST" action="/projeto_extensao/<%= id %>/questionarios/<%= q.id %>/delete" style="display:inline" onsubmit="return confirm('Excluir este questionário?')">
                      <button type="submit" class="btn btn-sm btn-outline-danger" style="font-size:0.75rem; padding:2px 6px" title="Excluir"><i class="bi bi-trash"></i></button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="7" class="text-center py-5 text-muted">
                <i class="bi bi-clipboard-x" style="font-size:2rem;opacity:0.3"></i>
                <p class="mt-2 mb-0">Nenhum questionário registrado</p>
                <a href="/projeto_extensao/<%= id %>/questionarios/novo" class="btn btn-primary btn-sm mt-2"><i class="bi bi-plus-circle"></i> Registrar primeiro questionário</a>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <div class="mt-3 d-flex gap-2">
      <a href="/projeto_extensao" class="btn btn-secondary btn-sm"><i class="bi bi-arrow-left"></i> Voltar aos Projetos</a>
      <a href="/projeto_extensao/<%= id %>/questionarios/pdf" class="btn btn-outline-primary btn-sm"><i class="bi bi-printer"></i> Imprimir Questionário em Branco</a>
    </div>
  </section>
</main>

<%- include('../rodape') %>
