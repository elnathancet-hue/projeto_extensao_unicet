<%- include('../cabecalho', { titulo: 'Questionários de Impacto' }) %>

<main id="conteudo-principal-form" class="container my-5">
  <section class="card shadow p-4 p-md-5">
    <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
      <i class="bi bi-clipboard-check fs-4 me-2"></i>
      <h1 class="fs-4 fw-bold mb-0">Questionários de Impacto</h1>
    </div>

    <div class="d-flex justify-content-end mb-3">
      <a href="/questionario/forms/questionario" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-circle"></i> Novo Questionário
      </a>
    </div>

    <div class="table-responsive">
      <table class="table table-hover">
        <thead class="table-light">
          <tr>
            <th>ID</th>
            <th>Ação Extensionista</th>
            <th>Instituição</th>
            <th>Data</th>
            <th>Local</th>
            <th>Avaliação</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (dados && dados.length > 0) { %>
            <% dados.forEach(d => { %>
              <tr>
                <td><span class="badge bg-secondary"><%= d.id %></span></td>
                <td><%= d.nome_acao %></td>
                <td><%= d.instituicao %></td>
                <td><%= d.data_realizacao ? new Date(d.data_realizacao).toLocaleDateString('pt-BR') : '-' %></td>
                <td><%= d.local_realizacao %></td>
                <td><span class="badge bg-info"><%= d.aval_conteudo %></span></td>
                <td>
                  <a href="/questionario/<%= d.id %>/edit" class="btn btn-primary btn-sm"><i class="bi bi-pencil"></i> Editar</a>
                  <a href="/questionario/<%= d.id %>/delete" class="btn btn-danger btn-sm" onclick="return confirm('Tem certeza que deseja excluir?')"><i class="bi bi-trash"></i> Excluir</a>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr><td colspan="7" class="text-center py-4 text-muted">Nenhum questionário encontrado.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <div class="mt-3">
      <a href="/logo" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Voltar</a>
    </div>
  </section>
</main>

<%- include('../rodape') %>
