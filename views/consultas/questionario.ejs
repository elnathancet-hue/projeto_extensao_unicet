<%- include('../cabecalho', { titulo: 'Consulta de Impactos' }) %>

<div class="container mt-4">
  <div class="row mb-4 align-items-center border-bottom pb-3">
    <div class="col-md-6">
      <h2 class="h4 mb-0"><i class="bi bi-list-check"></i> Questionários de Impacto</h2>
    </div>
    <div class="col-md-6 text-end">
      <a href="/questionario/forms/questionario" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Novo Questionário
      </a>
    </div>
  </div>

  <div id="form-feedback-message" class="alert d-none" role="alert"></div>

  <div class="table-responsive shadow-sm rounded">
    <table class="table table-hover align-middle">
      <thead class="table-light">
        <tr>
          <th style="width: 80px;"><i class="bi bi-hash"></i> ID</th>
          <th><i class="bi bi-journal-text"></i> Ação Extensionista</th>
          <th><i class="bi bi-building"></i> Instituição</th>
          <th><i class="bi bi-calendar-event"></i> Data</th>
          <th><i class="bi bi-geo-alt"></i> Local</th>
          <th><i class="bi bi-star"></i> Avaliação</th>
          <th class="text-center"><i class="bi bi-gear"></i> Ações</th>
        </tr>
      </thead>
      <tbody>
        <% if (dados && dados.length > 0) { %>
          <% dados.forEach(d => { %>
            <tr>
              <td>
                <span class="badge rounded-pill bg-secondary px-3"><%= d.id %></span>
              </td>
              <td class="fw-semibold"><%= d.nome_acao %></td>
              <td><%= d.instituicao %></td>
              <td><%= d.data_realizacao ? new Date(d.data_realizacao).toLocaleDateString('pt-BR') : 'N/A' %></td>
              <td><%= d.local_realizacao %></td>
              <td>
                <span class="badge bg-info text-dark"><%= d.aval_conteudo %></span>
              </td>
                <td class="text-nowrap align-middle">
    <a href="/projeto_custo/<%= d.Id %>/edit" class="text-success me-3" title="Editar" style="text-decoration: none; font-weight: 500;">
      <i class="bi bi-pencil-square me-1"></i> Editar
    </a>

    <a href="/projeto_custo/<%= d.Id %>/delete" class="text-danger" title="Deletar" style="text-decoration: none; font-weight: 500;" onclick="return confirm('Tem certeza que deseja deletar este custo?')">
      <i class="bi bi-trash-fill me-1"></i> Deletar
    </a>
  </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="7" class="text-center py-4 text-muted">
              <i class="bi bi-info-circle me-1"></i> Nenhum questionário encontrado no banco de dados.
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="mt-4">
    <a href="/logo" class="btn btn-secondary">
      <i class="bi bi-arrow-left"></i> Voltar
    </a>
  </div>
</div>

<%- include('../rodape') %>