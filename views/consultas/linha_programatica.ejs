<%- include('../cabecalho') %>

<div class="container mt-4">
  <div class="row mb-4 align-items-center">
    <div class="col-md-6">
      <h2><i class="bi bi-diagram-2"></i> Linhas Programáticas</h2>
    </div>
    <div class="col-md-6 text-end">
      <a href="/linha_programatica/forms/linha_programatica" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Novo
      </a>
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-md-12">
      <form method="POST" action="/linha_programatica/filtro" class="d-flex gap-2">
        <input type="text" name="nome" class="form-control" placeholder="Buscar por descrição...">
        <button type="submit" class="btn btn-outline-secondary">
          <i class="bi bi-search"></i> Buscar
        </button>
      </form>
    </div>
  </div>

  <div class="table-responsive shadow-sm rounded">
    <table class="table table-hover align-middle">
      <thead class="table-light">
        <tr>
          <th style="width: 80px;"><i class="bi bi-hash"></i> ID</th>
          <th><i class="bi bi-text-left"></i> Descrição</th>
          <th style="width: 250px;" class="text-center"><i class="bi bi-gear"></i> Ações</th>
        </tr>
      </thead>
      <tbody>
        <% dados.forEach(item => { %>
          <tr>
            <td><span class="badge rounded-pill bg-secondary px-3"><%= item.id_linha %></span></td>
            <td class="fw-semibold"><%= item.nome || item.descricao %></td>
            <td>
              <div class="d-flex justify-content-center gap-2">
                <a href="/linha_programatica/<%= item.id_linha %>/edit" class="btn btn-sm btn-warning d-flex align-items-center">
                  <i class="bi bi-pencil me-1"></i> Editar
                </a>

                <form method="POST" action="/linha_programatica/<%= item.id_linha %>/delete" style="display: inline;">
                  <button type="submit" class="btn btn-sm btn-danger d-flex align-items-center" onclick="return confirm('Tem certeza que deseja excluir?')">
                    <i class="bi bi-trash me-1"></i> Deletar
                  </button>
                </form>
              </div>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <div class="mt-4">
    <a href="/logo" class="btn btn-secondary">
      <i class="bi bi-arrow-left"></i> Voltar
    </a>
  </div>
</div>

<%- include('../rodape') %>