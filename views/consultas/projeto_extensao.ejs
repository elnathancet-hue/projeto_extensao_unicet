<%- include('../cabecalho', { titulo: 'Projetos de Extensão' }) %>

<%
  const perfil = (typeof sessionTipo !== 'undefined') ? (sessionTipo || '').toLowerCase() : 'professor';
  const isAdmin = perfil === 'admin';
  const isCoord = perfil === 'coordenador';

  const statusLabels = {
    rascunho: { text: 'Rascunho', bg: 'bg-secondary', icon: 'bi-pencil' },
    em_avaliacao: { text: 'Em Avaliação', bg: 'bg-warning', icon: 'bi-hourglass-split' },
    aprovado: { text: 'Aprovado', bg: 'bg-success', icon: 'bi-check-circle' },
    rejeitado: { text: 'Rejeitado', bg: 'bg-danger', icon: 'bi-x-circle' },
    em_execucao: { text: 'Em Execução', bg: 'bg-info', icon: 'bi-play-circle' },
    concluido: { text: 'Concluído', bg: 'bg-primary', icon: 'bi-trophy' }
  };
%>

<main id="conteudo-principal-form" class="container my-5">
  <section class="card shadow p-4 p-md-5">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
      <div>
        <h1 class="fs-4 fw-bold mb-1"><i class="bi bi-briefcase me-2"></i>Projetos de Extensão</h1>
        <p class="text-muted mb-0" style="font-size:0.7rem">Gerencie seus projetos, planos e relatórios de extensão</p>
      </div>
      <a href="/projeto_extensao/forms/projeto_extensao" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-circle"></i> Novo Projeto
      </a>
    </div>

    <!-- Busca -->
    <% const f = typeof filters !== 'undefined' ? filters : {}; %>
    <form method="GET" action="/projeto_extensao" class="row g-2 mb-4 align-items-end">
      <div class="col-md-3">
        <label class="form-label">Título</label>
        <input type="text" name="titulo" class="form-control form-control-sm" placeholder="Buscar por título..." value="<%= f.titulo || '' %>">
      </div>
      <div class="col-md-2">
        <label class="form-label">Tipo</label>
        <select name="id_tipo_plano" class="form-select form-select-sm">
          <option value="">Todos</option>
          <% if (typeof tipoPlanos !== 'undefined' && tipoPlanos) { %>
            <% tipoPlanos.forEach(tp => { %>
              <option value="<%= tp.id_tipo_plano %>" <%= (f.id_tipo_plano == tp.id_tipo_plano) ? 'selected' : '' %>><%= tp.descricao %></option>
            <% }) %>
          <% } %>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label">Status</label>
        <select name="status" class="form-select form-select-sm">
          <option value="">Todos</option>
          <option value="rascunho" <%= f.status === 'rascunho' ? 'selected' : '' %>>Rascunho</option>
          <option value="em_avaliacao" <%= f.status === 'em_avaliacao' ? 'selected' : '' %>>Em Avaliação</option>
          <option value="aprovado" <%= f.status === 'aprovado' ? 'selected' : '' %>>Aprovado</option>
          <option value="rejeitado" <%= f.status === 'rejeitado' ? 'selected' : '' %>>Rejeitado</option>
          <option value="em_execucao" <%= f.status === 'em_execucao' ? 'selected' : '' %>>Em Execução</option>
          <option value="concluido" <%= f.status === 'concluido' ? 'selected' : '' %>>Concluído</option>
        </select>
      </div>
      <div class="col-auto d-flex gap-2">
        <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search"></i> Buscar</button>
        <a href="/projeto_extensao" class="btn btn-secondary btn-sm"><i class="bi bi-x-circle"></i> Limpar</a>
      </div>
    </form>

    <!-- Tabela de projetos -->
    <div class="table-responsive">
      <table class="table table-hover cfg-table">
        <thead class="table-light">
          <tr>
            <th style="width:40px">ID</th>
            <th>Projeto</th>
            <th style="width:100px">Status</th>
            <th style="width:120px">Período</th>
            <th style="width:50px">CH</th>
            <th style="width:180px">Documentos</th>
            <th style="width:130px">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (dados && dados.length) { %>
            <% dados.forEach(d => { %>
              <%
                const st = d.status || 'rascunho';
                const stInfo = statusLabels[st] || statusLabels.rascunho;
              %>
              <tr>
                <td><span class="badge bg-secondary"><%= d.id_projeto %></span></td>
                <td>
                  <strong style="font-size:0.813rem"><%= d.titulo %></strong>
                  <% if (d.coordenador_nome) { %>
                    <br><small class="text-muted" style="font-size:0.75rem"><i class="bi bi-person"></i> <%= d.coordenador_nome %></small>
                  <% } %>
                </td>
                <td>
                  <span class="badge <%= stInfo.bg %>" style="font-size:0.75rem">
                    <i class="bi <%= stInfo.icon %>"></i> <%= stInfo.text %>
                  </span>
                </td>
                <td>
                  <small class="text-muted" style="font-size:0.688rem">
                    <%= d.periodo_inicio ? new Date(d.periodo_inicio).toLocaleDateString('pt-BR') : '-' %>
                    <br>
                    <%= d.periodo_fim ? new Date(d.periodo_fim).toLocaleDateString('pt-BR') : '-' %>
                  </small>
                </td>
                <td>
                  <span class="badge bg-info"><%= d.carga_horaria_total || 0 %>h</span>
                </td>
                <td>
                  <div class="d-flex gap-1">
                    <a href="/projeto_extensao/<%= d.id_projeto %>/plano" class="btn btn-sm btn-outline-primary" style="font-size:0.75rem; padding:2px 6px">
                      <i class="bi bi-file-text"></i> Plano
                    </a>
                    <% if (st === 'aprovado' || st === 'em_execucao' || st === 'concluido' || isAdmin) { %>
                    <a href="/projeto_extensao/<%= d.id_projeto %>/relatorio" class="btn btn-sm btn-outline-success" style="font-size:0.75rem; padding:2px 6px">
                      <i class="bi bi-journal-text"></i> Relatório
                    </a>
                    <% } %>
                  </div>
                </td>
                <td>
                  <div class="d-flex gap-1 flex-wrap">
                    <!-- Botões de workflow por perfil -->
                    <% if (st === 'rascunho' && (perfil === 'professor' || isAdmin)) { %>
                      <form method="POST" action="/projeto_extensao/<%= d.id_projeto %>/status" style="display:inline" onsubmit="return confirm('Submeter este projeto para avaliação?')">
                        <input type="hidden" name="novo_status" value="em_avaliacao">
                        <button class="btn btn-sm btn-warning" style="font-size:0.75rem; padding:2px 5px" title="Submeter para Análise"><i class="bi bi-send"></i> Submeter</button>
                      </form>
                    <% } %>

                    <% if (st === 'em_avaliacao' && (isCoord || isAdmin)) { %>
                      <form method="POST" action="/projeto_extensao/<%= d.id_projeto %>/status" style="display:inline" onsubmit="return confirm('Aprovar este projeto?')">
                        <input type="hidden" name="novo_status" value="aprovado">
                        <button class="btn btn-sm btn-success" style="font-size:0.75rem; padding:2px 5px" title="Aprovar"><i class="bi bi-check-lg"></i> Aprovar</button>
                      </form>
                      <form method="POST" action="/projeto_extensao/<%= d.id_projeto %>/status" style="display:inline" onsubmit="return confirm('Rejeitar este projeto? O professor será notificado.')">
                        <input type="hidden" name="novo_status" value="rejeitado">
                        <button class="btn btn-sm btn-danger" style="font-size:0.75rem; padding:2px 5px" title="Rejeitar"><i class="bi bi-x-lg"></i> Rejeitar</button>
                      </form>
                    <% } %>

                    <% if (st === 'aprovado' && (isCoord || isAdmin)) { %>
                      <form method="POST" action="/projeto_extensao/<%= d.id_projeto %>/status" style="display:inline" onsubmit="return confirm('Iniciar execução deste projeto?')">
                        <input type="hidden" name="novo_status" value="em_execucao">
                        <button class="btn btn-sm btn-info" style="font-size:0.75rem; padding:2px 5px" title="Iniciar Execução"><i class="bi bi-play"></i> Executar</button>
                      </form>
                    <% } %>

                    <% if (st === 'em_execucao' && isAdmin) { %>
                      <form method="POST" action="/projeto_extensao/<%= d.id_projeto %>/status" style="display:inline" onsubmit="return confirm('Concluir este projeto? Esta ação finaliza o ciclo.')">
                        <input type="hidden" name="novo_status" value="concluido">
                        <button class="btn btn-sm btn-primary" style="font-size:0.75rem; padding:2px 5px" title="Concluir"><i class="bi bi-trophy"></i> Concluir</button>
                      </form>
                    <% } %>

                    <% if (st === 'rejeitado' && isAdmin) { %>
                      <form method="POST" action="/projeto_extensao/<%= d.id_projeto %>/status" style="display:inline" onsubmit="return confirm('Reabrir este projeto como rascunho?')">
                        <input type="hidden" name="novo_status" value="rascunho">
                        <button class="btn btn-sm btn-secondary" style="font-size:0.75rem; padding:2px 5px" title="Devolver para Rascunho"><i class="bi bi-arrow-counterclockwise"></i> Reabrir</button>
                      </form>
                    <% } %>

                    <!-- Editar/Excluir (só rascunho ou admin) -->
                    <% if (st === 'rascunho' || isAdmin) { %>
                      <a href="/projeto_extensao/<%= d.id_projeto %>/edit" class="btn btn-sm btn-outline-secondary" style="font-size:0.75rem; padding:2px 5px" title="Editar"><i class="bi bi-pencil"></i></a>
                    <% } %>
                    <% if (isAdmin) { %>
                      <a href="/projeto_extensao/<%= d.id_projeto %>/delete" class="btn btn-sm btn-outline-danger" style="font-size:0.75rem; padding:2px 5px" title="Excluir" onclick="return confirm('Tem certeza que deseja excluir este projeto?')"><i class="bi bi-trash"></i></a>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="7" class="text-center py-5 text-muted">
                <i class="bi bi-inbox" style="font-size:2rem;opacity:0.3"></i>
                <p class="mt-2 mb-0">Nenhum projeto encontrado</p>
                <a href="/projeto_extensao/forms/projeto_extensao" class="btn btn-primary btn-sm mt-2"><i class="bi bi-plus-circle"></i> Criar primeiro projeto</a>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <div class="mt-3">
      <a href="/logo" class="btn btn-secondary btn-sm"><i class="bi bi-arrow-left"></i> Voltar</a>
    </div>
  </section>
</main>

<%- include('../rodape') %>
