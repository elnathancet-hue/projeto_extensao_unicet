<%- include('../cabecalho', { titulo: 'Projetos de Extensão' }) %>

<main id="conteudo-principal-form" class="container my-5">
  <section id="secao-cadastro-projeto" class="card shadow p-4 p-md-5">
    <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
      <i class="bi bi-briefcase fs-4 me-2"></i>
      <h1 class="fs-4 fw-bold mb-0">Projetos de Extensão</h1>
    </div>

    <% const f = typeof filters !== 'undefined' ? filters : {}; %>
    <form method="GET" action="/projeto_extensao" class="row g-2 mb-3 align-items-end">
      <div class="col-md-3">
        <label class="form-label">Titulo</label>
        <input type="text" name="titulo" class="form-control form-control-sm" placeholder="Buscar por titulo..." value="<%= f.titulo || '' %>">
      </div>
      <div class="col-md-2">
        <label class="form-label">Tipo Plano</label>
        <select name="id_tipo_plano" class="form-select form-select-sm">
          <option value="">Todos</option>
          <% if (typeof tipoPlanos !== 'undefined' && tipoPlanos) { %>
            <% tipoPlanos.forEach(tp => { %>
              <option value="<%= tp.id_tipo_plano %>" <%= (f.id_tipo_plano == tp.id_tipo_plano) ? 'selected' : '' %>><%= tp.descricao %></option>
            <% }) %>
          <% } %>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label">Inicio De</label>
        <input type="date" name="periodo_inicio_de" class="form-control form-control-sm" value="<%= f.periodo_inicio_de || '' %>">
      </div>
      <div class="col-md-2">
        <label class="form-label">Inicio Ate</label>
        <input type="date" name="periodo_inicio_ate" class="form-control form-control-sm" value="<%= f.periodo_inicio_ate || '' %>">
      </div>
      <div class="col-auto d-flex gap-2">
        <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search"></i> Filtrar</button>
        <a href="/projeto_extensao" class="btn btn-secondary btn-sm"><i class="bi bi-x-circle"></i> Limpar</a>
      </div>
    </form>

    <div class="d-flex justify-content-between align-items-center mb-3">
      <span class="fw-semibold">Inserir novo registro</span>
      <a href="/projeto_extensao/forms/projeto_extensao" class="btn btn-primary btn-sm"><i class="bi bi-plus-circle"></i> Novo Projeto</a>
    </div>

    <div id="form-feedback-message" class="alert d-none" role="alert"></div>

    <div class="table-responsive">
      <table class="table table-striped table-hover">
        <thead class="table-light">
          <tr>
            <th>ID</th>
            <th>Título</th>
            <th>Período</th>
            <th>Horas</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (dados && dados.length) { %>
            <% dados.forEach(d => { %>
              <tr>
                <td>
                  <span class="badge bg-secondary"><%= d.id_projeto %></span>
                </td>
                <td><%= d.titulo %></td>
                <td>
                  <small class="text-muted">
                    <%= d.periodo_inicio ? new Date(d.periodo_inicio).toLocaleDateString('pt-BR') : '-' %> até
                    <%= d.periodo_fim ? new Date(d.periodo_fim).toLocaleDateString('pt-BR') : '-' %>
                  </small>
                </td>
                <td>
                  <span class="badge bg-info"><%= d.carga_horaria_total || 0 %>h</span>
                </td>
                <td>
                  <a href="/projeto_extensao/<%= d.id_projeto %>/edit" class="btn btn-primary btn-sm" title="Editar">
                    <i class="bi bi-pencil"></i> Editar
                  </a>
                  <a href="/projeto_extensao/<%= d.id_projeto %>/delete" class="btn btn-danger btn-sm" title="Excluir" onclick="return confirm('Tem certeza?')">
                    <i class="bi bi-trash"></i> Excluir
                  </a>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="5" class="text-center py-4 text-muted">Nenhum projeto encontrado.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <div class="mt-3">
      <a href="/logo" class="btn btn-secondary"><i class="bi bi-arrow-left"></i>Voltar</a>
    </div>
  </section>
</main>

<%- include('../rodape') %>
