<%- include('../cabecalho', { titulo: 'Gerenciar Usuários' }) %>

<main id="conteudo-principal-form" class="container my-5">
  <section class="card shadow p-4 p-md-5">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
      <div>
        <h1 class="fs-4 fw-bold mb-1"><i class="bi bi-person-gear me-2"></i>Gerenciar Usuários</h1>
        <p class="text-muted mb-0" style="font-size:0.7rem">Cadastre e gerencie os acessos ao sistema</p>
      </div>
      <a href="/usuarios/forms/usuario" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-circle"></i> Novo Usuário
      </a>
    </div>

    <div class="table-responsive">
      <table class="table table-hover">
        <thead class="table-light">
          <tr>
            <th style="width:40px">ID</th>
            <th>Login</th>
            <th>Pessoa Vinculada</th>
            <th style="width:120px">Perfil</th>
            <th style="width:100px"></th>
          </tr>
        </thead>
        <tbody>
          <% if (dados && dados.length) { %>
            <% dados.forEach(u => { %>
              <%
                const perfilBg = u.tipo === 'admin' ? 'bg-danger' : u.tipo === 'coordenador' ? 'bg-warning' : 'bg-info';
              %>
              <tr>
                <td><span class="badge bg-secondary"><%= u.id_usuario %></span></td>
                <td><strong style="font-size:0.813rem"><%= u.usuario %></strong></td>
                <td>
                  <% if (u.nome_pessoa) { %>
                    <span style="font-size:0.813rem"><i class="bi bi-person"></i> <%= u.nome_pessoa %></span>
                  <% } else { %>
                    <span class="text-muted" style="font-size:0.75rem">Não vinculado</span>
                  <% } %>
                </td>
                <td>
                  <span class="badge <%= perfilBg %>" style="font-size:0.75rem; text-transform:uppercase"><%= u.tipo || 'professor' %></span>
                </td>
                <td>
                  <div class="d-flex gap-1">
                    <a href="/usuarios/<%= u.id_usuario %>/edit" class="btn btn-sm btn-outline-secondary" style="font-size:0.75rem; padding:2px 6px" title="Editar"><i class="bi bi-pencil"></i></a>
                    <form method="POST" action="/usuarios/<%= u.id_usuario %>/delete" style="display:inline" onsubmit="return confirm('Excluir o usuário &quot;<%= u.usuario %>&quot;? Esta ação não pode ser desfeita.')"><button type="submit" class="btn btn-sm btn-outline-danger" style="font-size:0.75rem; padding:2px 6px" title="Excluir"><i class="bi bi-trash"></i></button></form>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="5" class="text-center py-4 text-muted">
                <i class="bi bi-person-x" style="font-size:1.5rem;opacity:0.3"></i>
                <p class="mt-2 mb-0">Nenhum usuário cadastrado</p>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <% if (typeof pagination !== 'undefined' && pagination && pagination.totalPages > 1) { %>
      <nav aria-label="Paginação" class="mt-3">
        <div class="d-flex justify-content-between align-items-center">
          <small class="text-muted"><%= pagination.total %> usuário(s)</small>
          <ul class="pagination pagination-sm mb-0">
            <li class="page-item <%= pagination.page <= 1 ? 'disabled' : '' %>">
              <a class="page-link" href="?page=<%= pagination.page - 1 %>">Anterior</a>
            </li>
            <% for (let i = 1; i <= pagination.totalPages; i++) { %>
              <li class="page-item <%= i === pagination.page ? 'active' : '' %>">
                <a class="page-link" href="?page=<%= i %>"><%= i %></a>
              </li>
            <% } %>
            <li class="page-item <%= pagination.page >= pagination.totalPages ? 'disabled' : '' %>">
              <a class="page-link" href="?page=<%= pagination.page + 1 %>">Próximo</a>
            </li>
          </ul>
        </div>
      </nav>
    <% } %>

    <div class="mt-3">
      <a href="/logo" class="btn btn-secondary btn-sm"><i class="bi bi-arrow-left"></i> Voltar</a>
    </div>
  </section>
</main>

<%- include('../rodape') %>
