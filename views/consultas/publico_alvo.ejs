<%- include('../cabecalho', { titulo: 'Consulta de P&#xFA;blico-Alvo' }) %>

<main id="conteudo-principal-form" class="container my-5">
  <section class="card shadow p-4 p-md-5">
    <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
      <i class="bi bi-people fs-4 me-2"></i>
      <h1 class="fs-4 fw-bold mb-0">P&#xFA;blicos-Alvo</h1>
    </div>

    <div class="d-flex justify-content-end align-items-center mb-3">
      <a href="/publico_alvo/forms/publico_alvo" class="btn btn-primary btn-sm"><i class="bi bi-plus-circle"></i> Novo</a>
    </div>

    <div class="table-responsive">
      <table class="table table-hover">
        <thead class="table-light">
          <tr>
            <th>ID</th>
            <th>Descri&#xE7;&#xE3;o</th>
            <th>A&#xE7;&#xF5;es</th>
          </tr>
        </thead>
        <tbody>
          <% dados.forEach(item => { %>
            <tr>
              <td><span class="badge bg-secondary"><%= item.id_publico_alvo %></span></td>
              <td><% if (item.descricao) { %><%= item.descricao %><% } else if (item.nome) { %><%= item.nome %><% } %></td>
              <td>
                <a href="/publico_alvo/<%= item.id_publico_alvo %>/edit" class="btn btn-primary btn-sm">
                  <i class="bi bi-pencil"></i> Editar
                </a>
                <form method="POST" action="/publico_alvo/<%= item.id_publico_alvo %>/delete" style="display: inline;">
                  <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Tem certeza?')">
                    <i class="bi bi-trash"></i> Excluir
                  </button>
                </form>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <div class="mt-3">
      <a href="/logo" class="btn btn-secondary"><i class="bi bi-arrow-left"></i>Voltar</a>
    </div>
  </section>
</main>

<%- include('../rodape') %>
