<%- include('../cabecalho', { titulo: 'Consulta de Cronograma' }) %>

<main id="conteudo-principal-form" class="container my-5">
  <section class="card shadow p-4 p-md-5">
    <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
      <i class="bi bi-calendar-event fs-4 me-2"></i>
      <h1 class="fs-4 fw-bold mb-0">Cronograma de Atividades</h1>
    </div>

    <% const f = typeof filters !== 'undefined' ? filters : {}; %>
    <form method="GET" action="/cronograma" class="row g-2 mb-3 align-items-end">
      <div class="col-md-3">
        <label class="form-label">Etapa</label>
        <input type="text" name="etapa" class="form-control form-control-sm" placeholder="Buscar por etapa..." value="<%= f.etapa || '' %>">
      </div>
      <div class="col-md-3">
        <label class="form-label">Local</label>
        <input type="text" name="local" class="form-control form-control-sm" placeholder="Buscar por local..." value="<%= f.local || '' %>">
      </div>
      <div class="col-auto d-flex gap-2">
        <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search"></i> Buscar</button>
        <a href="/cronograma" class="btn btn-secondary btn-sm"><i class="bi bi-x-circle"></i> Limpar</a>
      </div>
    </form>

    <div class="d-flex justify-content-between align-items-center mb-3">
      <span class="fw-semibold">Atividades Cadastradas</span>
      <a href="/cronograma/forms/cronograma" class="btn btn-primary btn-sm"><i class="bi bi-plus-circle"></i> Novo</a>
    </div>

    <div class="table-responsive">
      <table class="table table-hover">
        <thead class="table-light">
          <tr>
            <th>ID</th>
            <th>N&#xBA;</th>
            <th>Etapa</th>
            <th>Data</th>
            <th>Hora</th>
            <th>Local</th>
            <th>A&#xE7;&#xF5;es</th>
          </tr>
        </thead>
        <tbody>
          <% if (dados && dados.length) { %>
            <% dados.forEach(d => { %>
              <tr>
                <td><span class="badge bg-secondary"><%= d.id %></span></td>
                <td><%= d.numero %></td>
                <td><%= d.etapa %></td>
                <td><%= d.data %></td>
                <td><%= d.hora %></td>
                <td><%= d.local %></td>
                <td>
                  <a href="/cronograma/<%= d.id %>/edit" class="btn btn-primary btn-sm">
                    <i class="bi bi-pencil"></i> Editar
                  </a>
                  <form method="POST" action="/cronograma/<%= d.id %>/delete" style="display: inline;">
                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Tem certeza?')">
                      <i class="bi bi-trash"></i> Excluir
                    </button>
                  </form>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="7" class="text-center py-4 text-muted">Nenhum registro encontrado.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <div class="mt-3">
      <a href="/logo" class="btn btn-secondary"><i class="bi bi-arrow-left"></i>Voltar</a>
    </div>
  </section>
</main>

<%- include('../rodape') %>
