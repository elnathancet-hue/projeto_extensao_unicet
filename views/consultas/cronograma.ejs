<%- include('../cabecalho', { titulo: 'Consulta de Cronograma' }) %>

<div class="container my-5">

  <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
    <h1 class="h4 mb-0">
      <i class="bi bi-calendar-event"></i> Cronograma de Atividades
    </h1>
    <a href="/cronograma/forms/cronograma" class="btn btn-success">
      <i class="bi bi-plus-lg"></i> Nova Atividade
    </a>
  </div>

  <div id="form-feedback-message" class="alert d-none" role="alert"></div>

  <div class="d-flex justify-content-center">
    <div class="table-responsive w-100" style="max-width: 900px;">
      <table class="table table-hover">
        <thead class="table-light">
          <tr>
            <th><i class="bi bi-hash"></i> ID</th>
            <th><i class="bi bi-list-task"></i> Nº</th>
            <th><i class="bi bi-card-text"></i> Etapa</th>
            <th><i class="bi bi-calendar"></i> Data</th>
            <th><i class="bi bi-clock"></i> Hora</th>
            <th><i class="bi bi-geo-alt"></i> Local</th>
            <th><i class="bi bi-gear"></i> Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (dados && dados.length) { %>
            <% dados.forEach(d => { %>
              <tr>
                <td><span class="badge bg-primary"><%= d.id %></span></td>
                <td><%= d.numero %></td>
                <td><%= d.etapa %></td>
                <td><%= d.data %></td>
                <td><%= d.hora %></td>
                <td><%= d.local %></td>
                <td>
                  <a href="/cronograma/<%= d.id %>/edit" class="btn btn-primary btn-sm">
                    <i class="bi bi-pencil"></i> Editar
                  </a>
                  <a href="/cronograma/<%= d.id %>/delete" class="btn btn-danger btn-sm">
                    <i class="bi bi-trash"></i> Excluir
                  </a>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="7" class="text-center py-4 text-muted">
                Nenhuma atividade cadastrada.
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

<div class="mt-4">
  <a href="/logo" class="btn btn-secondary">
    <i class="bi bi-arrow-left"></i> Voltar
  </a>
</div>

</div>

<%- include('../rodape') %>