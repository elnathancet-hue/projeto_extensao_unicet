<%- include('../cabecalho', { titulo: 'Tipos de Instituição' }) %>

<main id="conteudo-principal-form" class="container my-5">
  <section class="card shadow p-4 p-md-5">
    <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
      <i class="bi bi-building fs-4 me-2"></i>
      <h1 class="fs-4 fw-bold mb-0">Tipos de Instituição</h1>
    </div>

    <div class="d-flex justify-content-end align-items-center mb-3">
      <a href="/tipo_instituicao/forms/tipo_instituicao" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-circle"></i> Novo
      </a>
    </div>

    <div class="table-responsive">
      <table class="table table-hover">
        <thead class="table-light">
          <tr>
            <th>ID</th>
            <th>Descrição</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (dados && dados.length) { %>
            <% dados.forEach(item => { %>
              <tr>
                <td><span class="badge bg-secondary"><%= item.id_tipo_instituicao %></span></td>
                <td><%= item.descricao %></td>
                <td>
                  <a href="/tipo_instituicao/<%= item.id_tipo_instituicao %>/edit" class="btn btn-primary btn-sm">
                    <i class="bi bi-pencil"></i> Editar
                  </a>
                  <form method="POST" action="/tipo_instituicao/<%= item.id_tipo_instituicao %>/delete" class="d-inline">
                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Tem certeza que deseja excluir?')">
                      <i class="bi bi-trash"></i> Excluir
                    </button>
                  </form>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="3" class="text-center py-4 text-muted">Nenhum registro encontrado.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <div class="mt-3">
      <a href="/logo" class="btn btn-secondary"><i class="bi bi-arrow-left"></i>Voltar</a>
    </div>
  </section>
</main>

<%- include('../rodape') %>
