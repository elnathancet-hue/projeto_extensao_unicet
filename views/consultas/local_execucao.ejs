<%- include('../cabecalho', { titulo: 'Locais de Execução' }) %>
<% const f = typeof filters !== 'undefined' ? filters : {}; %>

<main id="conteudo-principal-form" class="container my-5">
  <section class="card shadow p-4 p-md-5">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
      <h1 class="h4 mb-0">
        <i class="bi bi-geo-alt me-2"></i>Locais de Execução
      </h1>
      <a href="/configuracoes#secao-cadastro" class="btn btn-primary btn-sm">
        <i class="bi bi-arrow-left"></i> Voltar ao Cadastro
      </a>
    </div>

    <!-- Filtros segmentados -->
    <form method="GET" action="/local_execucao" class="row g-2 mb-3 align-items-end">
      <div class="col-md-3">
        <label class="form-label">Cidade</label>
        <input type="text" name="cidade" class="form-control form-control-sm" placeholder="Ex: Teresina" value="<%= f.cidade || '' %>">
      </div>
      <div class="col-md-3">
        <label class="form-label">Bairro</label>
        <input type="text" name="bairro" class="form-control form-control-sm" placeholder="Ex: Centro" value="<%= f.bairro || '' %>">
      </div>
      <div class="col-md-3">
        <label class="form-label">Endereço</label>
        <input type="text" name="endereco" class="form-control form-control-sm" placeholder="Rua, avenida..." value="<%= f.endereco || '' %>">
      </div>
      <div class="col-auto d-flex gap-2">
        <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search"></i> Filtrar</button>
        <a href="/local_execucao" class="btn btn-secondary btn-sm"><i class="bi bi-x-circle"></i> Limpar</a>
      </div>
    </form>

    <div class="table-responsive">
      <table class="table table-hover cfg-table">
        <thead class="table-light">
          <tr>
            <th style="width:50px">ID</th>
            <th>Endereço</th>
            <th>CEP</th>
            <th>Bairro</th>
            <th>Cidade</th>
            <th style="width:80px">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (dados && dados.length) { %>
            <% dados.forEach(item => { %>
              <tr>
                <td><span class="badge bg-secondary"><%= item.id_local %></span></td>
                <td><%= item.endereco || '-' %></td>
                <td><%= item.cep || '-' %></td>
                <td><%= item.bairro || '-' %></td>
                <td><%= item.cidade || '-' %></td>
                <td>
                  <div class="cfg-actions">
                    <a href="/local_execucao/<%= item.id_local %>/edit" class="btn btn-sm btn-outline-secondary" title="Editar"><i class="bi bi-pencil"></i></a>
                    <a href="/local_execucao/<%= item.id_local %>/delete" class="btn btn-sm btn-outline-danger" title="Excluir" onclick="return confirm('Excluir este local?')"><i class="bi bi-trash"></i></a>
                  </div>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="6" class="text-center py-4 text-muted">Nenhum registro encontrado.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <div class="mt-3">
      <a href="/configuracoes#secao-cadastro" class="btn btn-secondary btn-sm"><i class="bi bi-arrow-left"></i> Voltar</a>
    </div>
  </section>
</main>

<%- include('../rodape') %>
